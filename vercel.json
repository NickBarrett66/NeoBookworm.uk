{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/api/reg-lookup",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    },
    {
      "source": "/api/vdg-lookup",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ],
  "redirects": [
    { "source": "/he-tyres", "destination": "/he-tyres/", "permanent": true },
    { "source": "/ridgecoat-decorators", "destination": "/ridgecoat-decorators/", "permanent": true },
    { "source": "/demos/hartley-plumbing", "destination": "/demos/hartley-plumbing/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/intake-upload-session", "destination": "/api/intake?action=upload-session" },
    { "source": "/api/intake-finalize",       "destination": "/api/intake?action=finalize" },
    { "source": "/api/onboarding-intake",      "destination": "/api/intake?action=onboarding" },
    { "source": "/api/run-site-audit",         "destination": "/api/dashboard" },
    { "source": "/c/:slug/guides/", "destination": "/api/portal?slug=:slug&section=guides" },
    { "source": "/c/:slug/guides",  "destination": "/api/portal?slug=:slug&section=guides" },
    { "source": "/c/:slug/google-business/", "destination": "/api/portal?slug=:slug&section=google-business" },
    { "source": "/c/:slug/google-business",  "destination": "/api/portal?slug=:slug&section=google-business" },
    { "source": "/c/:slug/handover/",         "destination": "/api/portal?slug=:slug&section=handover" },
    { "source": "/c/:slug/handover",          "destination": "/api/portal?slug=:slug&section=handover" },
    { "source": "/c/:slug/review/",           "destination": "/api/portal?slug=:slug&section=review" },
    { "source": "/c/:slug/review",            "destination": "/api/portal?slug=:slug&section=review" },
    { "source": "/c/:slug/action",             "destination": "/api/portal-action?slug=:slug" },
    { "source": "/c/:slug/",                  "destination": "/api/portal?slug=:slug" },
    { "source": "/c/:slug",                   "destination": "/api/portal?slug=:slug" }
  ]
}
