function journeyFromStartOption(startOption) {
  return JOURNEY_FROM_START_OPTION[startOption] || 'J1';
}

function renderPromoteSection({ client, dashboardSource, sourceId, defaultJourney, pickJourney, email }) {
  if (client) {
    const portalUrl   = `/c/${encodeURIComponent(client.slug)}/`;
    const stageLabel  = STAGE_LABELS[client.stage] || client.stage;
    return `
      <div class="promote-section promote-linked" id="promote-section">
        <h3>Client</h3>
        <p>Already promoted · Journey <strong>${escHtml(client.journey || '—')}</strong> · ${escHtml(stageLabel)}</p>
        <div class="promote-actions">
          <button type="button" class="btn-promote-secondary" id="btn-promote-view-client" data-slug="${escAttr(client.slug)}">View in Clients tab</button>
          <a href="${escAttr(portalUrl)}" target="_blank" rel="noopener" class="btn-promote-secondary">Open portal ↗</a>
        </div>
      </div>`;
  }

  if (!email || !String(email).trim()) {
    return `
      <div class="promote-section" id="promote-section">
        <h3>Promote to client</h3>
        <p class="muted">This record has no email address — add one before promoting.</p>
      </div>`;
  }

  const journeySelect = pickJourney
    ? `<div class="promote-journey-row">
         <label for="promote-journey-select">Journey</label>
         <select id="promote-journey-select">
           ${JOURNEY_PICK_OPTIONS.map(o =>
             `<option value="${escAttr(o.id)}"${o.id === defaultJourney ? ' selected' : ''}>${escHtml(o.label)}</option>`
           ).join('')}
         </select>
       </div>`
    : `<input type="hidden" id="promote-journey-select" value="${escAttr(defaultJourney || 'J1')}">`;

  const journeyNote = pickJourney
    ? 'Choose the journey that matches what they asked for.'
    : `Journey <strong>${escHtml(defaultJourney || 'J1')}</strong> (from this enquiry’s start option).`;

  return `
    <div class="promote-section" id="promote-section">
      <h3>Promote to client</h3>
      <p>${journeyNote} Creates a client row, sends the first acknowledgement email, and opens their portal.</p>
      ${journeySelect}
      <div class="promote-actions">
        <button type="button" class="btn-promote" id="btn-promote-client">Promote to client</button>
        <span class="promote-status" id="promote-status"></span>
      </div>
    </div>`;
}

function wirePromoteSection({ client, dashboardSource, sourceId, defaultJourney, pickJourney, email, onPromoted }) {
  document.getElementById('btn-promote-view-client')?.addEventListener('click', e => {
    const slug = e.currentTarget.dataset.slug;
    document.getElementById('modal-overlay')?.classList.remove('open');
    state.tab = 'clients';
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.tab === 'clients');
    });
    loadClientDetail(slug);
  });

  if (client) return;

  const btn    = document.getElementById('btn-promote-client');
  const status = document.getElementById('promote-status');
  const sel    = document.getElementById('promote-journey-select');
  if (!btn) return;

  btn.addEventListener('click', async () => {
    const journey = pickJourney ? (sel?.value || defaultJourney) : (sel?.value || defaultJourney || 'J1');
    if (!confirm(`Promote to client on journey ${journey}? This sends the acknowledgement email.`)) return;

    btn.disabled = true;
    if (status) { status.textContent = 'Promoting…'; status.className = 'promote-status'; }

    try {
      const result = await apiPost({
        action:      'client_promote',
        source_type: PROMOTE_API_SOURCE[dashboardSource],
        source_id:   sourceId,
        journey,
      });

      let msg = `Client created: ${result.slug}`;
      if (result.acknowledged) {
        msg += ' · Acknowledgement sent';
      } else if (result.ack_reason === 'already_acknowledged') {
        msg += ' · Acknowledgement already sent';
      } else if (result.ack_reason === 'missing_current_url') {
        msg += ' · No ack (set current URL in Clients, then send J2-E1 or J3-E1 manually)';
      } else if (result.ack_error) {
        msg += ` · Ack failed: ${result.ack_error}`;
      } else if (result.ack_reason) {
        msg += ` · No ack (${result.ack_reason})`;
      }

      if (status) { status.textContent = msg; status.className = 'promote-status ok'; }

      if (typeof onPromoted === 'function') {
        setTimeout(() => onPromoted(result.slug), 800);
      }
    } catch (err) {
      if (status) { status.textContent = err.message; status.className = 'promote-status err'; }
      btn.disabled = false;
    }
  });
}

