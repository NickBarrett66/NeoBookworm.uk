  acknowledged:     'var(--amber)',
  researching:      'var(--blue)',
  building:         'var(--blue)',
  reviewing:        'var(--blue)',
  review_delivered: 'var(--blue)',
  preview_ready:    'var(--green)',
  revisions:        'var(--orange)',
  awaiting_payment: 'var(--red)',
  preparing_live:   'var(--green)',
  live:             'var(--green)',
  care_active:      'var(--green)',
  self_managed:     'var(--grey)',
  dropped_out:      'var(--grey)',
};

