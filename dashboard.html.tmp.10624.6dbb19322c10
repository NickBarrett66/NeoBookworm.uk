// ── API ───────────────────────────────────────────────────────────────────────
async function apiFetch(params) {
  const qs  = new URLSearchParams(params).toString();
  const res = await fetch(`/api/dashboard?${qs}`, {
    headers: { 'Authorization': `Bearer ${state.token}` },
  });
  const data = await res.json();
  if (!data.ok) throw new Error(data.error || 'API error');
  return data;
}

async function apiPost(body) {
  const res = await fetch('/api/dashboard', {
    method:  'POST',
    headers: { 'Authorization': `Bearer ${state.token}`, 'Content-Type': 'application/json' },
    body:    JSON.stringify(body),
  });
  const data = await res.json();
  if (!data.ok) throw new Error(data.error || 'Save failed');
  return data;
}

// ── Auth ──────────────────────────────────────────────────────────────────────
document.getElementById('btn-login').addEventListener('click', tryLogin);
document.getElementById('token-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') tryLogin();
});

async function tryLogin() {
  const token = document.getElementById('token-input').value.trim();
  if (!token) return;
  const btn = document.getElementById('btn-login');
  btn.textContent = 'Checking…'; btn.disabled = true;

  try {
    const res  = await fetch('/api/dashboard?action=summary', {
      headers: { 'Authorization': `Bearer ${token}` },
    });
    if (res.status === 401) throw new Error('Invalid token');
    const data = await res.json();
    if (!data.ok) throw new Error(data.error);

    state.token       = token;
    state.summaryData = data.data;
    state.enqUnhandled     = (data.enquiries?.total || 0) - (data.enquiries?.handled || 0);
    state.intakeUnhandled  = (data.intake?.total  || 0) - (data.intake?.handled  || 0);
    state.contactUnhandled = (data.contact?.total || 0) - (data.contact?.handled || 0);
    state.submissionsCounts = {
      enquiry: {
        total:     data.enquiries?.total || 0,
        unhandled: state.enqUnhandled,
      },
      intake: {
        total:     data.intake?.total || 0,
        unhandled: state.intakeUnhandled,
      },
      contact: {
        total:     data.contact?.total || 0,
        unhandled: state.contactUnhandled,
      },
    };
    sessionStorage.setItem('dash_token', token);

    updateSubmissionsBadge();
    document.getElementById('login-overlay').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    renderSummary(data.data);
  } catch (err) {
    document.getElementById('login-error').textContent = err.message;
  } finally {
    btn.textContent = 'Sign in'; btn.disabled = false;
  }
}

(function autoLogin() {
  const saved = sessionStorage.getItem('dash_token');
  if (!saved) return;
  document.getElementById('token-input').value = saved;
  tryLogin();
})();

function submissionsUnhandledTotal() {
  return state.enqUnhandled + state.intakeUnhandled + state.contactUnhandled;
}

function updateSubmissionsBadge() {
  const badge = document.getElementById('enq-badge');
  if (badge) badge.remove();
  const total = submissionsUnhandledTotal();
  if (total > 0) {
    const btn = document.getElementById('enq-tab-btn');
    const b = document.createElement('span');
    b.id = 'enq-badge'; b.className = 'tab-badge';
    b.textContent = total;
    btn.appendChild(b);
  }
}

function bumpSubmissionsCount(sourceType, handledDelta) {
  const key = sourceType === 'enquiry' ? 'enquiry' : sourceType;
  if (state.submissionsCounts?.[key]) {
    state.submissionsCounts[key].unhandled = Math.max(0, state.submissionsCounts[key].unhandled + handledDelta);
  }
}

// ── Tabs ──────────────────────────────────────────────────────────────────────
function closeRecordModals() {
  document.getElementById('modal-overlay')?.classList.remove('open');
  document.getElementById('email-modal-overlay')?.classList.remove('open');
}

/** True when the tab is already showing its top-level screen (no drill-down). */
function isTabAtRoot(tab) {
  if (tab === 'prospects') return state.view === 'summary';
  const recordModalOpen = document.getElementById('modal-overlay')?.classList.contains('open');
  if (tab === 'enquiries') {
    return !recordModalOpen
      && state.submissionsPage === 1
      && !state.submissionsSearch
      && state.submissionsHandled === 'all'
      && state.submissionsSource === 'all';
  }
  if (tab === 'campaigns') {
    const emailModalOpen = document.getElementById('email-modal-overlay')?.classList.contains('open');
    return !emailModalOpen && state.campView === 'list';
  }
  if (tab === 'clients') {
    return state.clientsView === 'list';
  }
  return true;
}

function goToTabRoot(tab) {
  closeRecordModals();
  document.getElementById('btn-back').style.display = 'none';
  if (tab === 'prospects') {
    state.view = 'summary';
    renderSummary(state.summaryData);
  } else if (tab === 'enquiries') {
    state.submissionsPage = 1;
    state.submissionsSearch = '';
    state.submissionsHandled = 'all';
    state.submissionsSource = 'all';
    loadSubmissionsList();
  } else if (tab === 'campaigns') {
    state.campView = 'list';
    state.campColFilters = EMPTY_CAMP_COL_FILTERS();
    state.campColSorts   = defaultCampSorts();
    loadCampaignsList();
  } else if (tab === 'clients') {
    state.clientsView        = 'list';
    state.clientsSearch      = '';
    state.clientsStageFilter = 'active';
    state.clientsPage        = 1;
    loadClientsList();
  }
}

document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = btn.dataset.tab;
    if (tab === state.tab) {
      if (!isTabAtRoot(tab)) goToTabRoot(tab);
      return;
    }
    state.tab = tab;
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
    goToTabRoot(tab);
  });
});

// ── Prospects: summary view ───────────────────────────────────────────────────
function renderSummary(rows) {
  state.view = 'summary';
  const main     = document.getElementById('main-content');
  const byStatus = Object.fromEntries(rows.map(r => [r.status, r.count]));
  const total    = rows.reduce((s, r) => s + r.count, 0);

  const pipelineRows = PIPELINE_STATUSES.map(s => ({ status: s, count: byStatus[s] || 0 }));
  const filteredRows = rows.filter(r => !PIPELINE_STATUSES.includes(r.status));

  setBreadcrumb([{ label: 'Prospects' }]);
  document.getElementById('btn-back').style.display = 'none';

  main.innerHTML = `
    <div class="summary-header">
      <h2>Prospects Overview</h2>
      <div class="total-badge"><strong>${total.toLocaleString()}</strong> total records</div>
    </div>
    <div class="section-label">Active pipeline</div>
    <div class="cards" id="pipeline-cards"></div>
    <div class="section-label">Filtered / archived</div>
    <div class="cards" id="filtered-cards"></div>
  `;

  renderCards('pipeline-cards', pipelineRows);
  renderCards('filtered-cards', filteredRows);
}

function renderCards(containerId, rows) {
  const container = document.getElementById(containerId);
  rows.forEach(({ status, count }) => {
    const colour = STATUS_COLOURS[status] || '#607090';
    const card = document.createElement('div');
    card.className = 'card';
    card.style.setProperty('--card-color', colour);
    card.innerHTML = `<div class="card-count">${count.toLocaleString()}</div><div class="card-label">${escHtml(status)}</div>`;
    card.addEventListener('click', () => {
      state.colFilters = EMPTY_COL_FILTERS();
      state.colSorts   = defaultProspectSorts(status);
      loadList(status);
    });
    container.appendChild(card);
  });
}

// ── Prospects: list view ──────────────────────────────────────────────────────
async function loadList(status, page = 1, { soft = false } = {}) {
  state.view = 'list'; state.currentStatus = status;
  state.currentPage = page;

  const main = document.getElementById('main-content');
  const canSoft = soft && main.querySelector('#records-tbody');
  if (!canSoft) {
    main.innerHTML = '<div class="state-msg">Loading records…</div>';
  } else {
    main.querySelector('.table-wrap')?.classList.add('is-loading');
  }
  setBreadcrumb([
    { label: 'Prospects', action: () => renderSummary(state.summaryData) },
    { label: status },
  ]);
  document.getElementById('btn-back').style.display = '';

  try {
    const cf = state.colFilters;
    const params = { action: 'list', status, page };
    if (cf.q_business)      params.q_business     = cf.q_business;
    if (cf.q_contact)       params.q_contact      = cf.q_contact;
    if (cf.q_trade)         params.q_trade        = cf.q_trade;
    if (cf.q_town)          params.q_town         = cf.q_town;
    if (cf.q_campaign)      params.q_campaign     = cf.q_campaign;
    if (cf.has_website !== '') params.has_website  = cf.has_website;
    if (cf.min_rating)      params.min_rating     = cf.min_rating;
    if (cf.max_rating)      params.max_rating     = cf.max_rating;
    if (cf.emailed_filter)  params.emailed_filter = cf.emailed_filter;
    state.colSorts.forEach((s, i) => {
      params[`sort${i + 1}_col`] = s.col;
      params[`sort${i + 1}_dir`] = s.dir;
    });
    renderList(await apiFetch(params));
  } catch (err) {
    main.innerHTML = `<div class="state-msg" style="color:var(--red)">${escHtml(err.message)}</div>`;
  } finally {
    main.querySelector('.table-wrap.is-loading')?.classList.remove('is-loading');
  }
}

function restoreProspectFilterFocus(main) {
  const col = state.focusFilterCol;
  if (!col) return;
  requestAnimationFrame(() => {
    const el = main.querySelector(`.col-filter[data-col="${col}"]`);
    if (!el || el.tagName === 'SELECT') return;
    el.focus();
    const n = el.value.length;
    if (el.setSelectionRange) el.setSelectionRange(n, n);
  });
}

function renderList({ data: rows, total, page, pageSize }) {
  const main       = document.getElementById('main-content');
  const totalPages = Math.ceil(total / pageSize);
  const status     = state.currentStatus;
  const cols       = getProspectCols(status);
  const colCount   = cols.length;
  const cf         = state.colFilters;
  const cs         = state.colSorts;
  const hasFilter  = Object.values(cf).some(v => v !== '');
  const hasSorts   = cs.length > 0;

  const headerCells = cols.map(({ label, col }) => {
    const sortIdx = cs.findIndex(s => s.col === col);
    const sorted  = sortIdx !== -1;
    const dir     = sorted ? cs[sortIdx].dir : '';
    const arrow   = dir === 'asc' ? '↑' : dir === 'desc' ? '↓' : '';
    const badge   = sorted ? `<span class="sort-badge">${sortIdx + 1}</span>` : '';
    const ind     = sorted ? `<span class="sort-indicator">${arrow}${badge}</span>` : '';
    const cls     = `sortable-th${sorted ? ' is-sorted' : ''}`;
    return `<th class="${cls}" data-sort-col="${col}">${escHtml(label)}${ind}</th>`;
  }).join('');

  const filterCells = cols.map(({ col }) => `<th>${prospectFilterCell(col, cf)}</th>`).join('');

  const barParts = [];
  if (hasFilter) barParts.push(`Filters active <button class="btn-clear-filters" id="btn-clear-filters">Clear filters</button>`);
  if (hasSorts) {
    const sortDesc = cs.map(s => `${cols.find(c => c.col === s.col)?.label ?? s.col} ${s.dir === 'asc' ? '↑' : '↓'}`).join(' → ');
    barParts.push(`Sorted: ${escHtml(sortDesc)} <button class="btn-clear-sorts" id="btn-clear-sorts">Clear sorts</button>`);
  }
  const activeBar = barParts.length
    ? `<div class="filter-active-bar">${barParts.join('<span class="sep"> · </span>')}</div>`
    : '';

  main.innerHTML = `
    <div class="list-header">
      <h2>${escHtml(status)} <span class="count-tag">${total.toLocaleString()} records</span></h2>
    </div>
    ${activeBar}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>${headerCells}</tr>
          <tr class="filter-row">${filterCells}</tr>
        </thead>
        <tbody id="records-tbody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <button id="pg-prev" ${page <= 1 ? 'disabled' : ''}>← Prev</button>
      <span>Page ${page} of ${Math.max(1, totalPages)}</span>
      <button id="pg-next" ${page >= totalPages ? 'disabled' : ''}>Next →</button>
    </div>
  `;

  const tbody = document.getElementById('records-tbody');
  if (!rows.length) {
    tbody.innerHTML = `<tr><td colspan="${colCount}" class="muted" style="padding:2rem;text-align:center">No records found</td></tr>`;
  } else {
    rows.forEach(row => {
      const tr = document.createElement('tr');
      tr.innerHTML = cols.map(({ col }) => {
        const inner = prospectDataCell(col, row);
        if (col === 'business_name' || col === 'has_website' || col === 'campaign_id' || col === 'campaign_priority') {
          return `<td>${inner}</td>`;
        }
        return `<td class="muted">${inner}</td>`;
      }).join('');
      tr.addEventListener('click', e => {
        if (e.target.closest('.camp-id-cell')) return;
        loadRecord(row.notion_id);
      });
      const campCell = tr.querySelector('.camp-id-cell');
      if (campCell) {
        campCell.addEventListener('click', async e => {
          e.stopPropagation();
          try {
            await navigator.clipboard.writeText(campCell.dataset.id);
            const prev = campCell.textContent;
            campCell.textContent = 'Copied!';
            setTimeout(() => { campCell.textContent = prev; }, 1200);
          } catch { /* clipboard not available */ }
        });
      }
      tbody.appendChild(tr);
    });
  }

  // Sort: click cycles unsorted→asc→desc→removed; max 3 active sorts
  main.querySelectorAll('.sortable-th').forEach(th => {
    th.addEventListener('click', () => {
      const col      = th.dataset.sortCol;
      const existing = state.colSorts.find(s => s.col === col);
      if (existing) {
        if (existing.dir === 'asc') {
          existing.dir = 'desc';
        } else {
          state.colSorts = state.colSorts.filter(s => s.col !== col);
        }
      } else if (state.colSorts.length < 3) {
        state.colSorts.push({ col, dir: 'asc' });
      }
      loadList(status, 1, { soft: true });
    });
  });

  // Filter inputs: debounced for text, immediate for selects
  main.querySelectorAll('.col-filter').forEach(input => {
    input.addEventListener('focus', () => { state.focusFilterCol = input.dataset.col; });
    const evt = input.tagName === 'SELECT' ? 'change' : 'input';
    input.addEventListener(evt, () => {
      state.colFilters[input.dataset.col] = input.value;
      clearTimeout(state.filterTimer);
      if (input.tagName === 'SELECT') {
        loadList(status, 1, { soft: true });
        return;
      }
      state.filterTimer = setTimeout(() => loadList(status, 1, { soft: true }), FILTER_DEBOUNCE_MS);
    });
  });
  restoreProspectFilterFocus(main);

  const clearFiltersBtn = document.getElementById('btn-clear-filters');
  if (clearFiltersBtn) {
    clearFiltersBtn.addEventListener('click', () => {
      state.colFilters = EMPTY_COL_FILTERS();
      loadList(status, 1);
    });
  }

  const clearSortsBtn = document.getElementById('btn-clear-sorts');
  if (clearSortsBtn) {
    clearSortsBtn.addEventListener('click', () => {
      state.colSorts = defaultProspectSorts(status);
      loadList(status, 1);
    });
  }

  document.getElementById('pg-prev').addEventListener('click', () => loadList(status, page - 1, { soft: true }));
  document.getElementById('pg-next').addEventListener('click', () => loadList(status, page + 1, { soft: true }));
}

// ── Prospects: record modal ───────────────────────────────────────────────────
const PROSPECT_DETAIL_SECTIONS = [
  {
    fields: [
      { key: 'business_name', label: 'Business name' },
      { key: 'contact_name', label: 'Contact name' },
      { key: 'email_address', label: 'Email', input: 'email' },
      { key: 'phone', label: 'Phone' },
      { key: 'trade_category', label: 'Trade' },
      { key: 'town', label: 'Town' },
      { key: 'address', label: 'Address' },
      { key: 'postcode', label: 'Postcode' },
    ],
  },
  {
    fields: [
      { key: 'has_website', label: 'Has website', input: 'has_website' },
      { key: 'website_url', label: 'Website URL', input: 'url' },
      { key: 'website_platform', label: 'Website platform' },
      { key: 'website_agency', label: 'Website agency' },
      { key: 'rating', label: 'Rating', input: 'number' },
      { key: 'review_count', label: 'Review count', input: 'number' },
      { key: 'postcard_score', label: 'Postcard score', input: 'number' },
      { key: 'prospect_segment', label: 'Prospect segment' },
    ],
  },
  {
    fields: [
      { key: 'company_type', label: 'Company type' },
      { key: 'ch_number', label: 'CH number' },
      { key: 'ch_status', label: 'CH status' },
      { key: 'ch_incorporation_date', label: 'Incorporation date' },
      { key: 'date_first_contacted', label: 'Date first contacted' },
      { key: 'last_email_sent', label: 'Last email sent' },
      { key: 'contact_count', label: 'Contact count', input: 'number' },
      { key: 'demo_url', label: 'Demo URL', input: 'url' },
    ],
  },
  {
    fields: [
      { key: 'status', label: 'Status', input: 'status' },
      { key: 'disqualify_reason', label: 'Disqualify reason', disqualifyOnly: true },
      { key: 'notes', label: 'Notes', input: 'textarea', full: true },
    ],
  },
  {
    fields: [
      { key: 'research_summary', label: 'Research summary', input: 'textarea', full: true },
    ],
  },
];

function prospectRecordValue(r, key) {
  if (key === 'notes') return r.notes ?? r.note ?? '';
  if (key === 'has_website') return r.has_website ? 'Yes' : 'No';
  const v = r[key];
  if (v === null || v === undefined || v === '') return null;
  return v;
}

function prospectFieldView(f, r) {
  const v = prospectRecordValue(r, f.key);
  if (v === null) return '<span class="field-value empty">—</span>';
  const safe = escHtml(String(v));
  if (f.input === 'email' && r.email_address) {
    return `<span class="field-value"><a href="mailto:${escAttr(r.email_address)}" target="_blank" rel="noopener">${safe}</a></span>`;
  }
  if (f.input === 'url' && r[f.key]) {
    return `<span class="field-value"><a href="${escAttr(r[f.key])}" target="_blank" rel="noopener">${safe}</a></span>`;
  }
  if (f.input === 'textarea') {
    return `<span class="field-value text-multiline">${safe}</span>`;
  }
  return `<span class="field-value">${safe}</span>`;
}

function prospectFieldEdit(f, r) {
  const id = `edit-${f.key}`;
  const raw = prospectRecordValue(r, f.key);
  const strVal = raw === null ? '' : String(raw);

  if (f.input === 'status') {
    const opts = ALL_STATUSES.map(s =>
      `<option value="${escAttr(s)}"${s === r.status ? ' selected' : ''}>${escHtml(s)}</option>`
    ).join('');
    return `<select id="${id}" data-key="${f.key}">${opts}</select>`;
  }
  if (f.input === 'has_website') {
    const hw = r.has_website ? '1' : '0';
    return `<select id="${id}" data-key="${f.key}">
      <option value="1"${hw === '1' ? ' selected' : ''}>Yes</option>
      <option value="0"${hw === '0' ? ' selected' : ''}>No</option>
    </select>`;
  }
  if (f.input === 'textarea') {
    return `<textarea id="${id}" data-key="${f.key}" class="text-multiline" placeholder="${escAttr(f.label)}…">${escHtml(strVal)}</textarea>`;
  }
  const type = f.input === 'email' ? 'email' : f.input === 'url' ? 'url' : f.input === 'number' ? 'number' : 'text';
  const step = f.input === 'number' ? ' step="any"' : '';
  return `<input type="${type}" id="${id}" data-key="${f.key}" value="${escAttr(strVal)}"${step}>`;
}

function prospectSectionsHtml(r, editing) {
  return PROSPECT_DETAIL_SECTIONS.map((section, si) => {
    const visibleFields = section.fields.filter(f => {
      if (!editing && f.key === 'research_summary' && !r.research_summary) return false;
      if (!editing && f.disqualifyOnly && r.status !== 'Disqualified' && !r.disqualify_reason) return false;
      return true;
    });
    if (!visibleFields.length) return '';

    const grid = editing ? 'field-grid record-edit-grid' : 'field-grid';
    const cells = visibleFields.map(f => {
      const full = f.full ? ' style="grid-column:1/-1"' : '';
      if (editing) {
        const disqCls = f.disqualifyOnly
          ? ' disqualify-row' + (r.status === 'Disqualified' ? ' visible' : '')
          : '';
        const disqId = f.disqualifyOnly ? ' id="disqualify-row"' : '';
        return `<div class="field-group${disqCls}"${disqId}${full}><label class="field-label" for="edit-${f.key}">${escHtml(f.label)}</label>${prospectFieldEdit(f, r)}</div>`;
      }
      return `<div class="field-group"${full}><span class="field-label">${escHtml(f.label)}</span>${prospectFieldView(f, r)}</div>`;
    }).join('');

    const divider = si > 0 ? '<hr class="section-divider">' : '';
    return `${divider}<div class="${grid}">${cells}</div>`;
  }).join('');
}

async function loadRecord(id) {
  const overlay = document.getElementById('modal-overlay');
  const body    = document.getElementById('modal-body');
  body.innerHTML = '<div class="state-msg" style="padding:2rem 0">Loading…</div>';
  overlay.classList.add('open');

  try {
    const { data: r, client } = await apiFetch({ action: 'record', id });
    body.innerHTML = renderRecordHtml(r, false, client);
    wireProspectEdit(r, false, client);
  } catch (err) {
    body.innerHTML = `<p style="color:var(--red)">${escHtml(err.message)}</p>`;
  }
}

function renderRecordHtml(r, editing, client = null) {
  const title = editing ? 'Edit record' : escHtml(r.business_name || 'Unknown');
  const subtitle = editing
    ? escHtml(r.status || '') + (r.trade_category ? ' · ' + escHtml(r.trade_category) : '')
    : escHtml(r.status || '') + (r.trade_category ? ' · ' + escHtml(r.trade_category) : '');

  const actions = editing
    ? `<button type="button" class="btn-save" id="btn-save">Save changes</button>
       <button type="button" class="btn-cancel-edit" id="btn-cancel-edit">Cancel</button>
       <span class="save-status" id="save-status"></span>`
    : `<button type="button" class="btn-edit" id="btn-prospect-edit">Edit record</button>`;

  const promoteBlock = editing ? '' : renderPromoteSection({
    client,
    dashboardSource: 'prospect',
    sourceId:        r.notion_id,
    defaultJourney:  r.has_website ? 'J2' : 'J1',
    pickJourney:     true,
    email:           r.email_address,
  });

  return `
    <h2 id="record-title">${title}</h2>
    <div class="modal-status" id="record-subtitle">${subtitle}</div>
    <div class="modal-actions">${actions}</div>
    ${promoteBlock}
    ${prospectSectionsHtml(r, editing)}
  `;
}

function readProspectEditValue(r, key, el) {
  if (key === 'has_website') return Number(el.value);
  if (key === 'rating' || key === 'review_count' || key === 'postcard_score' || key === 'contact_count') {
    const t = el.value.trim();
    return t === '' ? '' : Number(t);
  }
  return el.value;
}

function prospectFieldChanged(key, orig, next) {
  if (key === 'has_website') return Number(orig ? 1 : 0) !== Number(next);
  if (key === 'notes') return String(orig ?? '') !== String(next ?? '');
  if (orig === null || orig === undefined) orig = '';
  if (next === null || next === undefined) next = '';
  return String(orig) !== String(next);
}

function collectProspectFieldChanges(r) {
  const fields = {};
  document.querySelectorAll('#modal-body [data-key]').forEach(el => {
    const key = el.dataset.key;
    const next = readProspectEditValue(r, key, el);
    let orig = prospectRecordValue(r, key);
    if (key === 'has_website') orig = r.has_website ? 1 : 0;
    if (prospectFieldChanged(key, orig, next)) fields[key] = next;
  });
  return fields;
}

function applyProspectFieldUpdates(r, fields) {
  for (const [key, val] of Object.entries(fields)) {
    if (key === 'notes') { r.notes = val; r.note = val; }
    else if (key === 'has_website') r.has_website = val ? 1 : 0;
    else r[key] = val;
  }
}

function wireProspectEdit(r, editing, client = null) {
  if (!editing) {
    wirePromoteSection({
      client,
      dashboardSource: 'prospect',
      sourceId:        r.notion_id,
      defaultJourney:  r.has_website ? 'J2' : 'J1',
      pickJourney:     true,
      email:           r.email_address,
      onPromoted:      () => loadRecord(r.notion_id),
    });
    document.getElementById('btn-prospect-edit')?.addEventListener('click', () => {
      const body = document.getElementById('modal-body');
      body.innerHTML = renderRecordHtml(r, true, client);
      wireProspectEdit(r, true, client);
    });
    return;
  }

  const saveBtn    = document.getElementById('btn-save');
  const cancelBtn  = document.getElementById('btn-cancel-edit');
  const saveStatus = document.getElementById('save-status');
  const statusEl   = document.getElementById('edit-status');
  const disqualifyRow = document.getElementById('disqualify-row');

  const toggleDisqualify = () => {
    if (disqualifyRow && statusEl) {
      disqualifyRow.classList.toggle('visible', statusEl.value === 'Disqualified');
    }
  };
  toggleDisqualify();
  statusEl?.addEventListener('change', toggleDisqualify);

  cancelBtn?.addEventListener('click', () => {
    const body = document.getElementById('modal-body');
    body.innerHTML = renderRecordHtml(r, false, client);
    wireProspectEdit(r, false, client);
  });

  saveBtn?.addEventListener('click', async () => {
    const fields = collectProspectFieldChanges(r);
    if (!Object.keys(fields).length) {
      saveStatus.textContent = 'No changes to save';
      saveStatus.className = 'save-status';
      return;
    }

    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…';
    saveStatus.className = 'save-status';

    try {
      await apiPost({ action: 'update', id: r.notion_id, fields });
      applyProspectFieldUpdates(r, fields);

      const body = document.getElementById('modal-body');
      body.innerHTML = renderRecordHtml(r, false);
      wireProspectEdit(r, false);

      if (state.view === 'list' && fields.status !== undefined && state.currentStatus !== r.status) {
        loadList(state.currentStatus, state.currentPage);
      }
    } catch (err) {
      saveStatus.textContent = err.message;
      saveStatus.className = 'save-status err';
      saveBtn.disabled = false;
    }
  });
}

// ── Enquiries: unified list (landing + intake + contact) ─────────────────────
const SUBMISSIONS_SOURCE_LABELS = { enquiry: 'Enquiry', intake: 'Intake', contact: 'Contact' };

function submissionsOverviewHtml() {
  const c = state.submissionsCounts;
  if (!c) return '';
  const cards = [
    { key: 'enquiry', label: 'Landing enquiry' },
    { key: 'intake',  label: 'Intake form' },
    { key: 'contact', label: 'Contact form' },
  ];
  return `<div class="submissions-overview">
    <div class="section-label">By source</div>
    <div class="filter-btns" style="flex-wrap:wrap">
      ${cards.map(({ key, label }) => {
        const n = c[key];
        const active = state.submissionsSource === key ? ' source-active' : '';
        return `<button type="button" class="filter-btn${active}" data-source="${key}">
          <strong>${n.total.toLocaleString()}</strong> ${escHtml(label)}
          ${n.unhandled > 0 ? `<span class="tab-badge" style="margin-left:.35rem">${n.unhandled}</span>` : ''}
        </button>`;
      }).join('')}
    </div>
  </div>`;
}

/** Pill class for landing-enquiry email leg (Worker uses ok/failed/skipped/pending). */
function emailSyncPillClass(status) {
  const s = (status || '').toLowerCase();
  if (s === 'ok' || s === 'success') return 'ok';
  if (s === 'failed') return 'fail';
  return 'pending-pill';
}

function submissionStatusCell(row) {
  if (row.source_type === 'enquiry') {
    const emailCls = emailSyncPillClass(row.email_status);
    return `<span class="pill ${emailCls}">${escHtml(row.email_status || '—')}</span>`;
  }
  if (row.source_type === 'intake') {
    const statusCls = row.intake_status === 'complete' ? 'ok'
      : row.intake_status === 'in_progress' ? 'pending-pill'
      : row.intake_status === 'cancelled' ? 'fail' : 'unhandled';
    return `<span class="pill ${statusCls}">${escHtml(row.intake_status || '—')}</span>`;
  }
  if (row.message_preview) {
    return `<span class="muted" style="font-size:.8rem">${escHtml(row.message_preview)}${row.message_preview.length >= 80 ? '…' : ''}</span>`;
  }
  return '<span class="muted">—</span>';
}

async function loadSubmissionsList(page, q, handled, source, { soft = false } = {}) {
  if (page    !== undefined) state.submissionsPage    = page;
  if (q       !== undefined) state.submissionsSearch  = q;
  if (handled !== undefined) state.submissionsHandled = handled;
  if (source  !== undefined) state.submissionsSource  = source;

  const main = document.getElementById('main-content');
  const canSoft = soft && main.querySelector('#submissions-tbody');
  if (!canSoft) {
    main.innerHTML = '<div class="state-msg">Loading enquiries…</div>';
  } else {
    main.querySelector('.table-wrap')?.classList.add('is-loading');
  }
  setBreadcrumb([{ label: 'Enquiries' }]);
  document.getElementById('btn-back').style.display = 'none';

  try {
    renderSubmissionsList(await apiFetch({
      action:  'submissions_list',
      page:    state.submissionsPage,
      q:       state.submissionsSearch,
      handled: state.submissionsHandled,
      source:  state.submissionsSource,
    }), { soft: canSoft });
  } catch (err) {
    main.innerHTML = `<div class="state-msg" style="color:var(--red)">${escHtml(err.message)}</div>`;
  } finally {
    main.querySelector('.table-wrap.is-loading')?.classList.remove('is-loading');
  }
}

function renderSubmissionsList({ data: rows, total, page, pageSize }, { soft = false } = {}) {
  const main       = document.getElementById('main-content');
  const totalPages = Math.ceil(total / pageSize);
  const overview   = submissionsOverviewHtml();

  const listShell = `
    ${overview}
    <div class="list-header">
      <h2>Enquiries <span class="count-tag">${total.toLocaleString()} records</span></h2>
      <div class="list-controls">
        <div class="filter-btns">
          <button type="button" class="filter-btn${state.submissionsHandled === 'all' ? ' active' : ''}" data-handled="all">All</button>
          <button type="button" class="filter-btn${state.submissionsHandled === '0'   ? ' active' : ''}" data-handled="0">Unhandled</button>
          <button type="button" class="filter-btn${state.submissionsHandled === '1'   ? ' active' : ''}" data-handled="1">Handled</button>
        </div>
        <div class="filter-btns">
          <button type="button" class="filter-btn${state.submissionsSource === 'all' ? ' active' : ''}" data-source="all">All sources</button>
          <button type="button" class="filter-btn${state.submissionsSource === 'enquiry' ? ' active source-active' : ''}" data-source="enquiry">Enquiry</button>
          <button type="button" class="filter-btn${state.submissionsSource === 'intake' ? ' active source-active' : ''}" data-source="intake">Intake</button>
          <button type="button" class="filter-btn${state.submissionsSource === 'contact' ? ' active source-active' : ''}" data-source="contact">Contact</button>
        </div>
        <input type="search" id="submissions-search-input" placeholder="Search name, business, email, trade…" value="${escAttr(state.submissionsSearch)}">
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr>
          <th>Date</th><th>Source</th><th>Name</th><th>Business</th><th>Trade</th>
          <th>Handled</th><th>Status</th>
        </tr></thead>
        <tbody id="submissions-tbody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <button id="submissions-prev" ${page <= 1 ? 'disabled' : ''}>← Prev</button>
      <span>Page ${page} of ${Math.max(1, totalPages)}</span>
      <button id="submissions-next" ${page >= totalPages ? 'disabled' : ''}>Next →</button>
    </div>
  `;

  if (!soft) {
    main.innerHTML = listShell;
  } else {
    const overviewEl = main.querySelector('.submissions-overview');
    if (overviewEl) overviewEl.outerHTML = overview;
    else main.insertAdjacentHTML('afterbegin', overview);
    const countTag = main.querySelector('.count-tag');
    if (countTag) countTag.textContent = `${total.toLocaleString()} records`;
    main.querySelectorAll('.list-controls .filter-btn[data-handled]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.handled === state.submissionsHandled);
    });
    main.querySelectorAll('.list-controls .filter-btn[data-source]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.source === state.submissionsSource);
      btn.classList.toggle('source-active', btn.dataset.source === state.submissionsSource && btn.dataset.source !== 'all');
    });
    const searchInput = document.getElementById('submissions-search-input');
    if (searchInput && searchInput.value !== state.submissionsSearch) searchInput.value = state.submissionsSearch;
    const prevBtn = document.getElementById('submissions-prev');
    const nextBtn = document.getElementById('submissions-next');
    if (prevBtn) prevBtn.disabled = page <= 1;
    if (nextBtn) nextBtn.disabled = page >= totalPages;
    const pageSpan = main.querySelector('.pagination span');
    if (pageSpan) pageSpan.textContent = `Page ${page} of ${Math.max(1, totalPages)}`;
  }

  const tbody = document.getElementById('submissions-tbody');
  if (!tbody) return;
  tbody.innerHTML = '';
  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="muted" style="padding:2rem;text-align:center">No records found</td></tr>';
  } else {
    rows.forEach(row => {
      const tr = document.createElement('tr');
      const dt = row.created_at ? row.created_at.slice(0, 16).replace('T', ' ') : '—';
      const srcLabel = SUBMISSIONS_SOURCE_LABELS[row.source_type] || row.source_type;
      tr.innerHTML = `
        <td class="muted" style="white-space:nowrap">${escHtml(dt)}</td>
        <td><span class="src-pill src-${escAttr(row.source_type)}">${escHtml(srcLabel)}</span></td>
        <td>${escHtml(row.display_name || '—')}</td>
        <td>${escHtml(row.business_name || '—')}</td>
        <td class="muted">${escHtml(row.trade || '—')}</td>
        <td><span class="pill ${row.handled ? 'handled' : 'unhandled'}">${row.handled ? 'Yes' : 'No'}</span></td>
        <td>${submissionStatusCell(row)}</td>
      `;
      tr.addEventListener('click', () => loadSubmissionRecord(row.source_type, row.source_id));
      tbody.appendChild(tr);
    });
  }

  wireSubmissionsOverviewControls();
  if (!soft) wireSubmissionsListControls(page, totalPages);
}

function wireSubmissionsOverviewControls() {
  document.querySelectorAll('.submissions-overview .filter-btn[data-source]').forEach(btn => {
    btn.addEventListener('click', () => {
      loadSubmissionsList(1, state.submissionsSearch, state.submissionsHandled, btn.dataset.source);
    });
  });
}

function wireSubmissionsListControls(page, totalPages) {
  const main = document.getElementById('main-content');

  main.querySelectorAll('.list-controls .filter-btn[data-handled]').forEach(btn => {
    btn.addEventListener('click', () => {
      loadSubmissionsList(1, state.submissionsSearch, btn.dataset.handled, state.submissionsSource);
    });
  });

  main.querySelectorAll('.list-controls .filter-btn[data-source]').forEach(btn => {
    btn.addEventListener('click', () => {
      loadSubmissionsList(1, state.submissionsSearch, state.submissionsHandled, btn.dataset.source);
    });
  });

  const searchInput = document.getElementById('submissions-search-input');
  if (searchInput) {
    searchInput.addEventListener('input', e => {
      clearTimeout(state.submissionsFilterTimer);
      state.submissionsFilterTimer = setTimeout(
        () => loadSubmissionsList(1, e.target.value, state.submissionsHandled, state.submissionsSource, { soft: true }),
        FILTER_DEBOUNCE_MS
      );
    });
  }

  document.getElementById('submissions-prev')?.addEventListener('click', () => {
    loadSubmissionsList(page - 1, state.submissionsSearch, state.submissionsHandled, state.submissionsSource, { soft: true });
  });
  document.getElementById('submissions-next')?.addEventListener('click', () => {
    loadSubmissionsList(page + 1, state.submissionsSearch, state.submissionsHandled, state.submissionsSource, { soft: true });
  });
}

function loadSubmissionRecord(sourceType, id) {
  if (sourceType === 'enquiry') return loadEnquiryRecord(id);
  if (sourceType === 'intake')  return loadIntakeRecord(id);
  if (sourceType === 'contact') return loadContactRecord(id);
}


// ── Enquiries: record modal ───────────────────────────────────────────────────
async function loadEnquiryRecord(id) {
  const overlay = document.getElementById('modal-overlay');
  const body    = document.getElementById('modal-body');
  body.innerHTML = '<div class="state-msg" style="padding:2rem 0">Loading…</div>';
  overlay.classList.add('open');

  try {
    const { data: r, client } = await apiFetch({ action: 'enquiries_record', id });
    const defaultJourney = journeyFromStartOption(r.start_option);
    body.innerHTML = renderEnquiryHtml(r, client);
    wireEnquiryEdit(r);
    wirePromoteSection({
      client,
      dashboardSource: 'enquiry',
      sourceId:        r.id,
      defaultJourney,
      pickJourney:     false,
      email:           r.email,
      onPromoted:      () => loadEnquiryRecord(id),
    });
  } catch (err) {
    body.innerHTML = `<p style="color:var(--red)">${escHtml(err.message)}</p>`;
  }
}

function renderEnquiryHtml(r, client = null) {
  const val = (v, link) => {
    if (!v && v !== 0) return '<span class="field-value empty">—</span>';
    const safe = escHtml(String(v));
    if (link) return `<span class="field-value"><a href="${escAttr(link)}" target="_blank" rel="noopener">${safe}</a></span>`;
    return `<span class="field-value">${safe}</span>`;
  };

  const dt         = r.created_at ? r.created_at.slice(0, 16).replace('T', ' ') : '—';
  const startLabel = START_OPTION_LABELS[r.start_option] || r.start_option || '—';
  const emailCls   = emailSyncPillClass(r.email_status);

  return `
    <h2>${escHtml(r.biz_name || 'Unknown')}</h2>
    <div class="modal-status">${escHtml(dt)} · ${escHtml(r.source || '')} · ${escHtml(startLabel)}</div>

    <div class="field-grid">
      <div class="field-group"><span class="field-label">Name</span>${val(r.full_name)}</div>
      <div class="field-group"><span class="field-label">Email</span>${val(r.email, r.email ? 'mailto:' + r.email : null)}</div>
      <div class="field-group"><span class="field-label">Source</span>${val(r.source)}</div>
      <div class="field-group"><span class="field-label">Start option</span>${val(startLabel)}</div>
      <div class="field-group"><span class="field-label">Current URL</span>${val(r.current_url, r.current_url)}</div>
      <div class="field-group">
        <span class="field-label">Email notify</span>
        <span class="field-value">
          <span class="pill ${emailCls}">${escHtml(r.email_status || '—')}</span>
        </span>
      </div>
    </div>

    ${r.details ? `
      <hr class="section-divider">
      <div class="field-group" style="grid-column:1/-1">
        <span class="field-label">Details / message</span>
        <span class="field-value text-multiline">${escHtml(r.details)}</span>
      </div>
    ` : ''}

    ${r.email_error ? `
      <hr class="section-divider">
      <div class="field-group"><span class="field-label">Email error</span><span class="field-value" style="color:var(--red)">${escHtml(r.email_error)}</span></div>
    ` : ''}

    ${renderPromoteSection({
      client,
      dashboardSource: 'enquiry',
      sourceId:        r.id,
      defaultJourney:  journeyFromStartOption(r.start_option),
      pickJourney:     false,
      email:           r.email,
    })}

    <div class="edit-section">
      <h3>Edit enquiry</h3>
      <div class="edit-row">
        <div class="checkbox-row">
          <input type="checkbox" id="edit-handled" ${r.handled ? 'checked' : ''}>
          <label for="edit-handled">Mark as handled</label>
        </div>
      </div>
      <div class="edit-row">
        <label for="edit-admin-notes">Admin notes</label>
        <textarea id="edit-admin-notes" class="text-multiline" placeholder="Internal notes…">${escHtml(r.admin_notes || '')}</textarea>
      </div>
      <div class="edit-actions">
        <button class="btn-save" id="enq-btn-save" disabled>Save changes</button>
        <span class="save-status" id="enq-save-status"></span>
        <button class="btn-delete" id="enq-btn-delete">Delete</button>
      </div>
    </div>
  `;
}

function wireEnquiryEdit(r) {
  const handledEl  = document.getElementById('edit-handled');
  const notesEl    = document.getElementById('edit-admin-notes');
  const saveBtn    = document.getElementById('enq-btn-save');
  const saveStatus = document.getElementById('enq-save-status');

  wireDeleteButton({
    btnId:            'enq-btn-delete',
    action:           'enquiries_delete',
    recordId:         r.id,
    isUnhandled:      !r.handled,
    unhandledStateKey:'enqUnhandled',
    badgeFn:          updateSubmissionsBadge,
    onDeleted:        () => loadSubmissionsList(state.submissionsPage, state.submissionsSearch, state.submissionsHandled, state.submissionsSource),
  });

  const origHandled = r.handled ? true : false;
  const origNotes   = r.admin_notes || '';

  const checkDirty = () => {
    const dirty = handledEl.checked !== origHandled || notesEl.value !== origNotes;
    saveBtn.disabled = !dirty;
    if (!dirty) { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }
  };

  handledEl.addEventListener('change', checkDirty);
  notesEl.addEventListener('input',   checkDirty);

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…'; saveStatus.className = 'save-status';

    const fields = {};
    if (handledEl.checked !== origHandled) fields.handled     = handledEl.checked ? 1 : 0;
    if (notesEl.value     !== origNotes)   fields.admin_notes = notesEl.value;

    try {
      await apiPost({ action: 'enquiries_update', id: r.id, fields });
      if (fields.handled     !== undefined) r.handled     = fields.handled;
      if (fields.admin_notes !== undefined) r.admin_notes = fields.admin_notes;

      if (fields.handled !== undefined) {
        state.enqUnhandled = Math.max(0, state.enqUnhandled + (fields.handled ? -1 : 1));
        bumpSubmissionsCount('enquiry', fields.handled ? -1 : 1);
        updateSubmissionsBadge();
      }

      saveStatus.textContent = 'Saved'; saveStatus.className = 'save-status ok';
      setTimeout(() => { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }, 2500);
      wireEnquiryEdit(r);

      if (state.tab === 'enquiries') {
        loadSubmissionsList(state.submissionsPage, state.submissionsSearch, state.submissionsHandled, state.submissionsSource, { soft: true });
      }
    } catch (err) {
      saveStatus.textContent = err.message; saveStatus.className = 'save-status err';
      saveBtn.disabled = false;
    }
  });
}

// ── Intake: record modal ──────────────────────────────────────────────────────
async function loadIntakeRecord(id) {
  const overlay = document.getElementById('modal-overlay');
  const body    = document.getElementById('modal-body');
  body.innerHTML = '<div class="state-msg" style="padding:2rem 0">Loading…</div>';
  overlay.classList.add('open');

  try {
    const { data: r, client } = await apiFetch({ action: 'intake_record', id });
    body.innerHTML = renderIntakeHtml(r, client);
    wireIntakeEdit(r);
    wirePromoteSection({
      client,
      dashboardSource: 'intake',
      sourceId:        r.id,
      defaultJourney:  'J4',
      pickJourney:     false,
      email:           r.email,
      onPromoted:      () => loadIntakeRecord(id),
    });
  } catch (err) {
    body.innerHTML = `<p style="color:var(--red)">${escHtml(err.message)}</p>`;
  }
}

function renderIntakeHtml(r, client = null) {
  const val = (v, link) => {
    if (!v && v !== 0) return '<span class="field-value empty">—</span>';
    const safe = escHtml(String(v));
    if (link) return `<span class="field-value"><a href="${escAttr(link)}" target="_blank" rel="noopener">${safe}</a></span>`;
    return `<span class="field-value">${safe}</span>`;
  };
  const valM = v => (!v && v !== 0) ? '<span class="field-value empty">—</span>' : `<span class="field-value text-multiline">${escHtml(String(v))}</span>`;

  let photoUrls = [];
  try { photoUrls = JSON.parse(r.photo_urls || '[]'); } catch { /* ignore */ }

  const photosHtml = photoUrls.length
    ? photoUrls.map((u, i) => `<a href="${escAttr(u)}" target="_blank" rel="noopener" style="color:var(--amber);display:block;margin-bottom:.2rem">Photo ${i + 1}</a>`).join('')
    : '<span class="field-value empty">—</span>';

  const statusOptions = INTAKE_STATUSES.map(s =>
    `<option value="${escAttr(s)}"${s === r.status ? ' selected' : ''}>${escHtml(s)}</option>`
  ).join('');

  const dt = r.created_at ? r.created_at.slice(0, 16).replace('T', ' ') : '—';
  const statusCls = r.status === 'complete' ? 'ok' : r.status === 'in_progress' ? 'pending-pill' : r.status === 'cancelled' ? 'fail' : 'unhandled';

  return `
    <h2>${escHtml(r.business_name || 'Unknown')}</h2>
    <div class="modal-status">${escHtml(dt)} · <span class="pill ${statusCls}">${escHtml(r.status || '—')}</span></div>

    <div class="field-grid">
      <div class="field-group"><span class="field-label">Full name</span>${val(r.full_name)}</div>
      <div class="field-group"><span class="field-label">Email</span>${val(r.email, r.email ? 'mailto:' + r.email : null)}</div>
      <div class="field-group"><span class="field-label">Phone</span>${val(r.phone)}</div>
      <div class="field-group"><span class="field-label">Trade</span>${val(r.trade_category)}</div>
      <div class="field-group"><span class="field-label">Area</span>${val(r.area)}</div>
      <div class="field-group"><span class="field-label">Years trading</span>${val(r.years_trading)}</div>
    </div>
    <hr class="section-divider">
    <div class="field-grid">
      <div class="field-group"><span class="field-label">Services</span>${val(r.services)}</div>
      <div class="field-group"><span class="field-label">Accreditations</span>${val(r.accreditations)}</div>
      <div class="field-group"><span class="field-label">Free quotes</span>${val(r.free_quotes)}</div>
      <div class="field-group"><span class="field-label">Emergency callouts</span>${val(r.emergency_callouts)}</div>
      <div class="field-group"><span class="field-label">Google Business</span>${val(r.google_business)}</div>
      <div class="field-group"><span class="field-label">Domain status</span>${val(r.domain_status)}</div>
      <div class="field-group"><span class="field-label">Domain name</span>${val(r.domain_name)}</div>
      <div class="field-group"><span class="field-label">Contact methods</span>${val(r.contact_methods)}</div>
      <div class="field-group"><span class="field-label">Working hours</span>${val(r.working_hours)}</div>
      <div class="field-group"><span class="field-label">Team size</span>${val(r.team_size)}</div>
    </div>
    <hr class="section-divider">
    <div class="field-grid">
      <div class="field-group" style="grid-column:1/-1"><span class="field-label">About</span>${valM(r.about)}</div>
      <div class="field-group" style="grid-column:1/-1"><span class="field-label">Ideal work</span>${valM(r.ideal_work)}</div>
      <div class="field-group" style="grid-column:1/-1"><span class="field-label">Work exclusions</span>${valM(r.work_exclusions)}</div>
      <div class="field-group"><span class="field-label">Colour preferences</span>${val(r.colour_preferences)}</div>
      <div class="field-group"><span class="field-label">Website style</span>${val(r.website_style)}</div>
      <div class="field-group"><span class="field-label">Inspiration URL</span>${val(r.inspiration_url, r.inspiration_url)}</div>
      <div class="field-group"><span class="field-label">Testimonials</span>${valM(r.testimonials)}</div>
      <div class="field-group"><span class="field-label">Trust marks</span>${val(r.trust_marks)}</div>
    </div>
    <hr class="section-divider">
    <div class="field-grid">
      <div class="field-group"><span class="field-label">Logo</span>${val(r.logo_url, r.logo_url)}</div>
      <div class="field-group"><span class="field-label">Notion page</span>${r.notion_page_id ? val('View in Notion', 'https://www.notion.so/' + r.notion_page_id.replace(/-/g, '')) : '<span class="field-value empty">—</span>'}</div>
      <div class="field-group" style="grid-column:1/-1"><span class="field-label">Work photos (${photoUrls.length})</span>${photosHtml}</div>
    </div>
    ${r.additional_notes ? `<hr class="section-divider"><div class="field-group" style="grid-column:1/-1"><span class="field-label">Additional notes</span><span class="field-value text-multiline">${escHtml(r.additional_notes)}</span></div>` : ''}

    ${renderPromoteSection({
      client,
      dashboardSource: 'intake',
      sourceId:        r.id,
      defaultJourney:  'J4',
      pickJourney:     false,
      email:           r.email,
    })}

    <div class="edit-section">
      <h3>Edit record</h3>
      <div class="edit-row"><label for="intake-edit-status">Status</label><select id="intake-edit-status">${statusOptions}</select></div>
      <div class="edit-row">
        <div class="checkbox-row">
          <input type="checkbox" id="intake-edit-handled" ${r.handled ? 'checked' : ''}>
          <label for="intake-edit-handled">Mark as handled</label>
        </div>
      </div>
      <div class="edit-row"><label for="intake-edit-notes">Admin notes</label><textarea id="intake-edit-notes" class="text-multiline" placeholder="Internal notes…">${escHtml(r.admin_notes || '')}</textarea></div>
      <div class="edit-actions">
        <button class="btn-save" id="intake-btn-save" disabled>Save changes</button>
        <span class="save-status" id="intake-save-status"></span>
        <button class="btn-delete" id="intake-btn-delete">Delete</button>
      </div>
    </div>
  `;
}

function wireIntakeEdit(r) {
  const statusEl   = document.getElementById('intake-edit-status');
  const handledEl  = document.getElementById('intake-edit-handled');
  const notesEl    = document.getElementById('intake-edit-notes');
  const saveBtn    = document.getElementById('intake-btn-save');
  const saveStatus = document.getElementById('intake-save-status');

  wireDeleteButton({
    btnId:            'intake-btn-delete',
    action:           'intake_delete',
    recordId:         r.id,
    isUnhandled:      !r.handled,
    unhandledStateKey:'intakeUnhandled',
    badgeFn:          updateSubmissionsBadge,
    onDeleted:        () => loadSubmissionsList(state.submissionsPage, state.submissionsSearch, state.submissionsHandled, state.submissionsSource),
  });

  const origStatus  = r.status || '';
  const origHandled = r.handled ? true : false;
  const origNotes   = r.admin_notes || '';

  const checkDirty = () => {
    const dirty = statusEl.value !== origStatus || handledEl.checked !== origHandled || notesEl.value !== origNotes;
    saveBtn.disabled = !dirty;
    if (!dirty) { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }
  };

  statusEl.addEventListener('change', checkDirty);
  handledEl.addEventListener('change', checkDirty);
  notesEl.addEventListener('input', checkDirty);

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…'; saveStatus.className = 'save-status';
    const fields = {};
    if (statusEl.value      !== origStatus)  fields.status      = statusEl.value;
    if (handledEl.checked   !== origHandled) fields.handled     = handledEl.checked ? 1 : 0;
    if (notesEl.value       !== origNotes)   fields.admin_notes = notesEl.value;

    try {
      await apiPost({ action: 'intake_update', id: r.id, fields });
      if (fields.status      !== undefined) r.status      = fields.status;
      if (fields.handled     !== undefined) r.handled     = fields.handled;
      if (fields.admin_notes !== undefined) r.admin_notes = fields.admin_notes;

      if (fields.handled !== undefined) {
        state.intakeUnhandled = Math.max(0, state.intakeUnhandled + (fields.handled ? -1 : 1));
        bumpSubmissionsCount('intake', fields.handled ? -1 : 1);
        updateSubmissionsBadge();
      }

      saveStatus.textContent = 'Saved'; saveStatus.className = 'save-status ok';
      setTimeout(() => { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }, 2500);
      wireIntakeEdit(r);

      if (state.tab === 'enquiries') loadSubmissionsList(state.submissionsPage, state.submissionsSearch, state.submissionsHandled, state.submissionsSource, { soft: true });
    } catch (err) {
      saveStatus.textContent = err.message; saveStatus.className = 'save-status err';
      saveBtn.disabled = false;
    }
  });
}

// ── Contact: record modal ─────────────────────────────────────────────────────
async function loadContactRecord(id) {
  const overlay = document.getElementById('modal-overlay');
  const body    = document.getElementById('modal-body');
  body.innerHTML = '<div class="state-msg" style="padding:2rem 0">Loading…</div>';
  overlay.classList.add('open');

  try {
    const { data: r, client } = await apiFetch({ action: 'contact_record', id });
    body.innerHTML = renderContactHtml(r, client);
    wireContactEdit(r);
    wirePromoteSection({
      client,
      dashboardSource: 'contact',
      sourceId:        r.id,
      defaultJourney:  'J5',
      pickJourney:     true,
      email:           r.email,
      onPromoted:      () => loadContactRecord(id),
    });
  } catch (err) {
    body.innerHTML = `<p style="color:var(--red)">${escHtml(err.message)}</p>`;
  }
}

function renderContactHtml(r, client = null) {
  const val = (v, link) => {
    if (!v && v !== 0) return '<span class="field-value empty">—</span>';
    const safe = escHtml(String(v));
    if (link) return `<span class="field-value"><a href="${escAttr(link)}" target="_blank" rel="noopener">${safe}</a></span>`;
    return `<span class="field-value">${safe}</span>`;
  };

  const dt = r.created_at ? r.created_at.slice(0, 16).replace('T', ' ') : '—';

  return `
    <h2>${escHtml(r.name || 'Unknown')}</h2>
    <div class="modal-status">${escHtml(dt)}${r.trade ? ' · ' + escHtml(r.trade) : ''}</div>

    <div class="field-grid">
      <div class="field-group"><span class="field-label">Name</span>${val(r.name)}</div>
      <div class="field-group"><span class="field-label">Email</span>${val(r.email, r.email ? 'mailto:' + r.email : null)}</div>
      <div class="field-group"><span class="field-label">Trade</span>${val(r.trade)}</div>
      <div class="field-group"><span class="field-label">Handled</span><span class="pill ${r.handled ? 'handled' : 'unhandled'}">${r.handled ? 'Yes' : 'No'}</span></div>
    </div>

    ${r.message ? `
      <hr class="section-divider">
      <div class="field-group" style="grid-column:1/-1">
        <span class="field-label">Message</span>
        <span class="field-value text-multiline">${escHtml(r.message)}</span>
      </div>
    ` : ''}

    ${renderPromoteSection({
      client,
      dashboardSource: 'contact',
      sourceId:        r.id,
      defaultJourney:  'J5',
      pickJourney:     true,
      email:           r.email,
    })}

    <div class="edit-section">
      <h3>Edit enquiry</h3>
      <div class="edit-row">
        <div class="checkbox-row">
          <input type="checkbox" id="contact-edit-handled" ${r.handled ? 'checked' : ''}>
          <label for="contact-edit-handled">Mark as handled</label>
        </div>
      </div>
      <div class="edit-row"><label for="contact-edit-notes">Admin notes</label><textarea id="contact-edit-notes" class="text-multiline" placeholder="Internal notes…">${escHtml(r.admin_notes || '')}</textarea></div>
      <div class="edit-actions">
        <button class="btn-save" id="contact-btn-save" disabled>Save changes</button>
        <span class="save-status" id="contact-save-status"></span>
        <button class="btn-delete" id="contact-btn-delete">Delete</button>
      </div>
    </div>
  `;
}

function wireContactEdit(r) {
  const handledEl  = document.getElementById('contact-edit-handled');
  const notesEl    = document.getElementById('contact-edit-notes');
  const saveBtn    = document.getElementById('contact-btn-save');
  const saveStatus = document.getElementById('contact-save-status');

  wireDeleteButton({
    btnId:            'contact-btn-delete',
    action:           'contact_delete',
    recordId:         r.id,
    isUnhandled:      !r.handled,
    unhandledStateKey:'contactUnhandled',
    badgeFn:          updateSubmissionsBadge,
    onDeleted:        () => loadSubmissionsList(state.submissionsPage, state.submissionsSearch, state.submissionsHandled, state.submissionsSource),
  });

  const origHandled = r.handled ? true : false;
  const origNotes   = r.admin_notes || '';

  const checkDirty = () => {
    const dirty = handledEl.checked !== origHandled || notesEl.value !== origNotes;
    saveBtn.disabled = !dirty;
    if (!dirty) { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }
  };

  handledEl.addEventListener('change', checkDirty);
  notesEl.addEventListener('input', checkDirty);

  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…'; saveStatus.className = 'save-status';
    const fields = {};
    if (handledEl.checked !== origHandled) fields.handled     = handledEl.checked ? 1 : 0;
    if (notesEl.value     !== origNotes)   fields.admin_notes = notesEl.value;

    try {
      await apiPost({ action: 'contact_update', id: r.id, fields });
      if (fields.handled     !== undefined) r.handled     = fields.handled;
      if (fields.admin_notes !== undefined) r.admin_notes = fields.admin_notes;

      if (fields.handled !== undefined) {
        state.contactUnhandled = Math.max(0, state.contactUnhandled + (fields.handled ? -1 : 1));
        bumpSubmissionsCount('contact', fields.handled ? -1 : 1);
        updateSubmissionsBadge();
      }

      saveStatus.textContent = 'Saved'; saveStatus.className = 'save-status ok';
      setTimeout(() => { saveStatus.textContent = ''; saveStatus.className = 'save-status'; }, 2500);
      wireContactEdit(r);

      if (state.tab === 'enquiries') loadSubmissionsList(state.submissionsPage, state.submissionsSearch, state.submissionsHandled, state.submissionsSource, { soft: true });
    } catch (err) {
      saveStatus.textContent = err.message; saveStatus.className = 'save-status err';
      saveBtn.disabled = false;
    }
  });
}

// ── Campaigns: list view ──────────────────────────────────────────────────────
async function loadCampaignsList({ soft = false } = {}) {
  state.campView = 'list';
  const main = document.getElementById('main-content');
  const canSoft = soft && main.querySelector('#camp-tbody');
  if (!canSoft) {
    main.innerHTML = '<div class="state-msg">Loading campaigns…</div>';
  } else {
    main.querySelector('.table-wrap')?.classList.add('is-loading');
  }
  setBreadcrumb([{ label: 'Campaigns' }]);
  document.getElementById('btn-back').style.display = 'none';

  try {
    const params = { action: 'campaigns_list' };
    appendCampaignListParams(params);
    const { data } = await apiFetch(params);
    renderCampaignsList(data);
  } catch (err) {
    main.innerHTML = `<div class="state-msg" style="color:var(--red)">${escHtml(err.message)}</div>`;
  } finally {
    main.querySelector('.table-wrap.is-loading')?.classList.remove('is-loading');
  }
}

function renderCampaignsList(rows) {
  const main   = document.getElementById('main-content');
  const n      = rows.length;
  const cols   = CAMPAIGN_COLS;
  const cf     = state.campColFilters;
  const cs     = state.campColSorts;
  const colN   = cols.length + 1;

  main.innerHTML = `
    <div class="list-header">
      <h2>Campaigns <span class="count-tag">${n} campaign${n !== 1 ? 's' : ''}</span></h2>
    </div>
    ${buildFilterActiveBar(cols, cf, cs, 'btn-camp-clear-filters', 'btn-camp-clear-sorts')}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>${buildSortHeaderCells(cols, cs)}<th>Action</th></tr>
          <tr class="filter-row">${cols.map(({ col }) => `<th>${campaignFilterCell(col, cf)}</th>`).join('')}<th></th></tr>
        </thead>
        <tbody id="camp-tbody"></tbody>
      </table>
    </div>
  `;

  wireColFilterSort(main, {
    cols, filters: cf, sorts: cs,
    focusKey: 'campFocusFilterCol', timerKey: 'campFilterTimer',
    onReload: loadCampaignsList,
    clearFilterId: 'btn-camp-clear-filters', clearSortId: 'btn-camp-clear-sorts',
    getDefaultSorts: defaultCampSorts,
  });

  const tbody = document.getElementById('camp-tbody');
  if (!rows.length) {
    tbody.innerHTML = `<tr><td colspan="${colN}" class="muted" style="padding:2rem;text-align:center">No campaigns found</td></tr>`;
    return;
  }
  rows.forEach(row => {
    const tr = document.createElement('tr');
    const dt     = row.created_at ? row.created_at.slice(0, 10) : '—';
    const status = (row.status || 'draft').toLowerCase();
    const total  = row.count_total  ?? 0;
    const sent   = row.count_sent   ?? 0;
    const sentPct = total > 0 ? Math.round((sent / total) * 100) : 0;
    const approved = row.count_approved != null ? row.count_approved : null;
    const approvedLine = approved != null
      ? `<div style="font-size:.75rem;color:${approved < total ? 'var(--amber)' : 'var(--muted)'}">${approved} / ${total} approved</div>`
      : `<div style="font-size:.75rem;color:var(--muted)">— / ${total} approved</div>`;
    const sentLine = `<div style="font-size:.75rem;color:var(--muted);display:flex;align-items:center;gap:.3rem">${sent} / ${total} sent<span class="prog-wrap"><span class="prog-fill" style="width:${sentPct}%"></span></span></div>`;
    const priority = row.priority != null ? 'P' + row.priority : '—';
    const rowId = String(row.id);
    if (status === 'complete') tr.classList.add('camp-row-complete');

    tr.innerHTML = `
      <td>${escHtml(row.trade || '—')}</td>
      <td><span class="camp-badge ${escAttr(status)}">${escHtml(row.status || 'draft')}</span></td>
      <td>${approvedLine}${sentLine}</td>
      <td>
        <div class="priority-cell" id="prio-cell-${escAttr(rowId)}">
          <button class="btn-boost" data-delta="-1" title="Lower priority">▼</button>
          <span class="priority-val">${escHtml(priority)}</span>
          <button class="btn-boost" data-delta="1" title="Raise priority">▲</button>
        </div>
      </td>
      <td class="muted">${row.count_replied ?? '—'}</td>
      <td class="muted">${escHtml(dt)}</td>
      <td><span class="camp-id-cell" data-id="${escAttr(rowId)}" title="${escAttr(rowId)}">${escHtml(rowId.slice(0, 25))}…</span></td>
      <td id="action-cell-${escAttr(rowId)}"></td>
    `;

    tr.addEventListener('click', e => {
      if (e.target.closest('.btn-boost, .btn-camp-action')) return;
      loadCampaignDetail(row.id, row);
    });

    // Wire priority boost buttons
    tr.querySelectorAll('.btn-boost').forEach(btn => {
      btn.addEventListener('click', async e => {
        e.stopPropagation();
        const delta = parseInt(btn.dataset.delta, 10);
        const cell  = document.getElementById('prio-cell-' + rowId);
        const valEl = cell?.querySelector('.priority-val');
        btn.disabled = true;
        const prev = valEl?.textContent;
        if (valEl) valEl.innerHTML = '<span class="spinner"></span>';
        try {
          const { new_priority } = await apiPost({ action: 'campaign_boost', id: row.id, delta });
          row.priority = new_priority;
          if (valEl) valEl.textContent = new_priority != null ? 'P' + new_priority : '—';
        } catch {
          if (valEl) valEl.textContent = prev;
        } finally {
          btn.disabled = false;
        }
      });
    });

    tbody.appendChild(tr);

    // Copy campaign ID on click
    tr.querySelector('.camp-id-cell').addEventListener('click', async e => {
      e.stopPropagation();
      const el = e.currentTarget;
      try {
        await navigator.clipboard.writeText(el.dataset.id);
        const prev = el.textContent;
        el.textContent = 'Copied!';
        setTimeout(() => { el.textContent = prev; }, 1200);
      } catch { /* clipboard not available */ }
    });

    // Wire action button (uses recursive helper so re-wiring after click is clean)
    const actionCell = document.getElementById('action-cell-' + rowId);
    wireCampActionBtn(actionCell, row, tr);
  });
}

function campActionBtnHtml(status) {
  const st = (status || 'draft').toLowerCase();
  if (st === 'complete') return '';
  if (st === 'draft')  return `<button class="btn-camp-action activate" data-action="campaign_activate">Activate</button>`;
  if (st === 'active') return `<button class="btn-camp-action pause"    data-action="campaign_pause">Pause</button>`;
  if (st === 'paused') return `<button class="btn-camp-action resume"   data-action="campaign_resume">Resume</button>`;
  return '';
}

function wireCampActionBtn(cell, row, tr) {
  const status = (row.status || 'draft').toLowerCase();
  cell.innerHTML = campActionBtnHtml(status);
  const btn = cell.querySelector('.btn-camp-action');
  if (!btn) return;
  btn.addEventListener('click', async e => {
    e.stopPropagation();
    const act = btn.dataset.action;
    btn.disabled = true;
    const origHtml = btn.innerHTML;
    btn.innerHTML = '<span class="spinner"></span>';
    try {
      await apiPost({ action: act, id: row.id });
      const newStatus = act === 'campaign_activate' ? 'active'
                      : act === 'campaign_pause'    ? 'paused'
                      : act === 'campaign_resume'   ? 'active' : status;
      row.status = newStatus;
      const badgeEl = tr.querySelector('.camp-badge');
      if (badgeEl) { badgeEl.className = `camp-badge ${newStatus}`; badgeEl.textContent = newStatus; }
      wireCampActionBtn(cell, row, tr);
    } catch {
      btn.innerHTML = origHtml;
      btn.disabled = false;
    }
  });
}

// ── Campaigns: detail view ────────────────────────────────────────────────────
async function loadCampaignDetail(id, rowHint, { soft = false, reloadOutboxOnly = false } = {}) {
  state.campView = 'detail';
  state.campCampaignId = id;
  const main = document.getElementById('main-content');
  const canSoft = soft && (reloadOutboxOnly
    ? document.getElementById('outbox-section')
    : document.getElementById('camp-detail-tbody'));
  if (!canSoft) {
    main.innerHTML = '<div class="state-msg">Loading campaign…</div>';
  } else {
    (reloadOutboxOnly
      ? document.getElementById('outbox-section')?.closest('.table-wrap')
      : document.getElementById('camp-detail-tbody')?.closest('.table-wrap')
    )?.classList.add('is-loading');
  }
  const label = rowHint?.trade ? `${rowHint.trade} — ${String(id)}` : String(id);
  setBreadcrumb([
    { label: 'Campaigns', action: () => loadCampaignsList() },
    { label: label },
  ]);
  document.getElementById('btn-back').style.display = '';

  try {
    const detailParams = { action: 'campaigns_detail', id };
    if (!reloadOutboxOnly) appendCampDetailProspectParams(detailParams);
    const outboxParams = { action: 'outbox_list', campaign_id: id };
    appendOutboxListParams(outboxParams);

    const fetches = reloadOutboxOnly
      ? [apiFetch(outboxParams)]
      : [apiFetch(detailParams), apiFetch(outboxParams)];

    const results = await Promise.all(fetches);
    const outboxRows = reloadOutboxOnly ? results[0].data : results[1].data;
    state.outboxRows       = outboxRows;
    state.outboxCampaignId = id;

    if (reloadOutboxOnly) {
      renderOutboxSection(outboxRows, id);
    } else {
      const { campaign, prospects } = results[0];
      renderCampaignDetail(campaign, prospects, outboxRows);
    }
  } catch (err) {
    if (!canSoft) {
      main.innerHTML = `<div class="state-msg" style="color:var(--red)">${escHtml(err.message)}</div>`;
    }
  } finally {
    document.querySelectorAll('.table-wrap.is-loading').forEach(el => el.classList.remove('is-loading'));
  }
}

function renderCampaignDetail(c, prospects, outboxRows) {
  const main      = document.getElementById('main-content');
  const sentTotal = `${c.count_sent ?? 0} / ${c.count_total ?? 0}`;
  const campSt    = (c.status || 'draft').toLowerCase();
  const pCols     = CAMP_DETAIL_PROSPECT_COLS;
  const pCf       = state.campDetailProspectFilters;
  const pCs       = state.campDetailProspectSorts;
  const pColN     = pCols.length;

  main.innerHTML = `
    <div class="list-header">
      <div>
        <h2>${escHtml(c.trade || 'Campaign')} <span class="count-tag">${escHtml(String(c.id || ''))}</span></h2>
        <div style="font-size:.82rem;color:var(--muted);margin-top:.3rem">
          <span class="camp-badge ${escAttr(campSt)}">${escHtml(c.status || 'draft')}</span>
          &nbsp;&nbsp;Sent ${escHtml(sentTotal)}
          &nbsp;&nbsp;Replied ${c.count_replied ?? '—'}
          ${c.notes ? `&nbsp;&nbsp;·&nbsp;&nbsp;${escHtml(c.notes)}` : ''}
        </div>
      </div>
    </div>
    <div class="section-label">Outbox</div>
    <div id="outbox-section"></div>
    <div class="section-label" style="margin-top:1.5rem">${prospects.length.toLocaleString()} prospect${prospects.length !== 1 ? 's' : ''} in this campaign</div>
    ${buildFilterActiveBar(pCols, pCf, pCs, 'btn-camp-pros-clear-filters', 'btn-camp-pros-clear-sorts')}
    <div class="table-wrap" id="camp-prospects-table-wrap">
      <table>
        <thead>
          <tr>${buildSortHeaderCells(pCols, pCs)}</tr>
          <tr class="filter-row">${pCols.map(({ col }) => `<th>${campDetailProspectFilterCell(col, pCf)}</th>`).join('')}</tr>
        </thead>
        <tbody id="camp-detail-tbody"></tbody>
      </table>
    </div>
  `;

  renderOutboxSection(outboxRows, c.id);

  wireColFilterSort(main, {
    cols: pCols, filters: pCf, sorts: pCs,
    focusKey: 'campDetailProspectFocusCol', timerKey: 'campDetailProspectFilterTimer',
    onReload: ({ soft }) => loadCampaignDetail(c.id, c, { soft }),
    clearFilterId: 'btn-camp-pros-clear-filters', clearSortId: 'btn-camp-pros-clear-sorts',
  });

  const tbody = document.getElementById('camp-detail-tbody');
  if (!prospects.length) {
    tbody.innerHTML = `<tr><td colspan="${pColN}" class="muted" style="padding:2rem;text-align:center">No prospects in this campaign</td></tr>`;
  } else {
    prospects.forEach(p => {
      const tr     = document.createElement('tr');
      const dt     = p.last_email_sent ? p.last_email_sent.slice(0, 10) : '—';
      const colour = STATUS_COLOURS[p.status] || '#607090';
      tr.innerHTML = `
        <td>${escHtml(p.business_name || '—')}</td>
        <td class="muted">${escHtml(p.contact_name || p.email_address || '—')}</td>
        <td class="muted">${escHtml(p.town || '—')}</td>
        <td><span class="pill" style="color:${colour};border-color:${colour}">${escHtml(p.status || '—')}</span></td>
        <td class="muted">${escHtml(dt)}</td>
        <td class="muted">${p.contact_count ?? '—'}</td>
      `;
      tr.addEventListener('click', () => loadRecord(p.notion_id));
      tbody.appendChild(tr);
    });
  }
}

// ── Outbox section ────────────────────────────────────────────────────────────
function outboxSeqLabel(seqNum) {
  const n = Number(seqNum) || 1;
  if (n === 1) return '1st Email';
  if (n === 2) return '2nd Email';
  if (n === 3) return 'Final Email';
  return n + 'th Email';
}

function groupOutboxByProspect(rows) {
  const map = new Map();
  rows.forEach(row => {
    const key = row.notion_id || row.id;
    if (!map.has(key)) {
      map.set(key, {
        notion_id: row.notion_id,
        business_name: row.business_name,
        email: row.email,
        rows: [],
      });
    }
    map.get(key).rows.push(row);
  });
  map.forEach(g => g.rows.sort((a, b) => (Number(a.seq_num) || 1) - (Number(b.seq_num) || 1)));
  return Array.from(map.values());
}

function computeOutboxSummaryStats(rows) {
  const now = new Date();
  const prospectIds = new Set(rows.map(r => r.notion_id || r.id));
  let embargoed = 0;
  let pending = 0;
  let suppressed = 0;
  rows.forEach(r => {
    if (r.suppressed) suppressed++;
    else if (!r.skipped && !r.sent && !r.approved) pending++;
    else if (!r.skipped && !r.sent && r.approved && r.scheduled_not_before && new Date(r.scheduled_not_before) > now) embargoed++;
  });
  return {
    prospectCount: prospectIds.size,
    totalEmails: rows.length,
    sent: rows.filter(r => r.sent).length,
    embargoed,
    pending,
    skipped: rows.filter(r => r.skipped).length,
    suppressed,
  };
}

function getProspectGroupBadge(group) {
  const rs = group.rows;
  const isSuppressed = rs.some(r => r.suppressed);
  const sentCount = rs.filter(r => r.sent).length;
  const skippedAny = rs.some(r => r.skipped);
  const unsent = rs.filter(r => !r.sent);
  const unsentApproved = unsent.filter(r => r.approved && !r.skipped && !r.suppressed);

  if (isSuppressed) return { text: '✦ Replied — stopped', color: 'var(--purple)', border: 'var(--purple)' };
  if (sentCount === rs.length) return { text: '✓ Complete', color: '#22c55e', border: '#22c55e' };
  if (sentCount > 0 && sentCount < rs.length) return { text: '→ In progress', color: 'var(--blue)', border: 'var(--blue)' };
  if (skippedAny) return { text: '⊘ Skipped', color: 'var(--grey)', border: 'var(--border)' };
  if (unsent.length && unsentApproved.length === unsent.length) return { text: '✓ Approved', color: '#4ade80', border: '#22c55e' };
  if (unsentApproved.length > 0) return { text: '◑ Part-approved', color: 'var(--amber)', border: 'var(--amber)' };
  return { text: '○ Pending', color: 'var(--muted)', border: 'var(--border)' };
}

function updateCampaignDetailBadgeIfComplete(rows) {
  if (!rows.length) return;
  const pending = rows.some(r => !r.sent && !r.skipped);
  if (pending) return;
  const badge = document.querySelector('#main-content .list-header .camp-badge');
  if (badge) {
    badge.className = 'camp-badge complete';
    badge.textContent = 'complete';
  }
}

function rerenderOutboxPreserveScroll(rows, campaignId) {
  const y = window.scrollY;
  renderOutboxSection(rows, campaignId);
  updateCampaignDetailBadgeIfComplete(rows);
  requestAnimationFrame(() => window.scrollTo(0, y));
}

function renderOutboxSection(rows, campaignId) {
  const section = document.getElementById('outbox-section');
  if (!section) return;

  const stats = computeOutboxSummaryStats(rows);
  const hasPending = rows.some(r => !r.approved && !r.sent && !r.skipped && !r.suppressed);
  const groups = groupOutboxByProspect(rows);
  const isGrouped = groups.some(g => g.rows.length > 1);
  const oCols   = OUTBOX_COLS;
  const oCf     = state.outboxColFilters;
  const oCs     = state.outboxColSorts;
  const dataColSpan = isGrouped ? 6 : 7;
  const outboxHeadCols = isGrouped
    ? [
        { label: 'Sequence', col: 'seq_num' },
        { label: 'Subject', col: 'subject' },
        { label: 'Scheduled', col: 'scheduled_not_before' },
        { label: 'Approval', col: 'approved' },
        { label: 'Status', col: 'sent' },
      ]
    : [
        { label: 'Business name', col: 'business_name' },
        { label: 'Email', col: 'email' },
        { label: 'Approval', col: 'approved' },
        { label: 'Status', col: 'sent' },
        { label: 'Scheduled', col: 'scheduled_not_before' },
      ];

  section.innerHTML = `
    <div class="outbox-summary-bar" id="outbox-summary-bar">
      <div class="summ-lines">
        <div><strong>${stats.prospectCount}</strong> prospect${stats.prospectCount !== 1 ? 's' : ''} in sequence</div>
        <div class="summ-line2">${stats.totalEmails} emails — ${stats.sent} sent · ${stats.embargoed} embargoed · ${stats.pending} awaiting approval · ${stats.skipped} skipped · ${stats.suppressed} suppressed</div>
      </div>
      <div class="summ-btns">
        <button class="btn-outbox-hdr review" id="btn-review-all" ${!hasPending ? 'disabled' : ''}>Review &amp; Approve All</button>
        <button class="btn-outbox-hdr approve-all" id="btn-approve-all" ${!hasPending ? 'disabled' : ''}>Approve All Emails</button>
      </div>
    </div>
    ${buildFilterActiveBar(oCols, oCf, oCs, 'btn-outbox-clear-filters', 'btn-outbox-clear-sorts')}
    <div class="table-wrap" id="outbox-table-wrap">
      <table>
        <thead>
          <tr>${isGrouped ? '' : '<th>#</th>'}${buildSortHeaderCells(outboxHeadCols, oCs)}<th>Actions</th></tr>
          <tr class="filter-row">
            ${isGrouped
              ? `<th></th>
                 <th>${outboxFilterCell('business_name', oCf)}</th>
                 <th>${outboxFilterCell('subject', oCf)}</th>
                 <th>${outboxFilterCell('approved', oCf)}</th>
                 <th>${outboxFilterCell('sent', oCf)}</th>
                 <th></th>`
              : `<th></th>
                 <th>${outboxFilterCell('business_name', oCf)}</th>
                 <th>${outboxFilterCell('email', oCf)}</th>
                 <th>${outboxFilterCell('approved', oCf)}</th>
                 <th>${outboxFilterCell('sent', oCf)}</th>
                 <th>${outboxFilterCell('subject', oCf)}</th>
                 <th></th>`}
          </tr>
        </thead>
        <tbody id="outbox-tbody"></tbody>
      </table>
    </div>
  `;

  wireColFilterSort(section, {
    cols: outboxHeadCols, filters: oCf, sorts: oCs,
    focusKey: 'outboxFocusFilterCol', timerKey: 'outboxFilterTimer',
    onReload: ({ soft }) => loadCampaignDetail(campaignId, null, { soft, reloadOutboxOnly: true }),
    clearFilterId: 'btn-outbox-clear-filters', clearSortId: 'btn-outbox-clear-sorts',
  });

  if (!rows.length) {
    document.getElementById('outbox-tbody').innerHTML =
      `<tr><td colspan="${dataColSpan}" class="muted" style="padding:1.5rem;text-align:center">No emails in outbox</td></tr>`;
  } else {
    renderOutboxRows(rows, campaignId, groups, isGrouped);
  }

  document.getElementById('btn-approve-all')?.addEventListener('click', async e => {
    const btn = e.currentTarget;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span>';
    try {
      await apiPost({ action: 'outbox_approve_all', campaign_id: campaignId });
      rows.forEach(r => { if (!r.sent && !r.skipped && !r.suppressed) r.approved = 1; });
      state.outboxRows = rows;
      rerenderOutboxPreserveScroll(rows, campaignId);
    } catch (err) {
      btn.disabled = false;
      btn.textContent = 'Approve All Emails';
      alert('Error: ' + err.message);
    }
  });

  document.getElementById('btn-review-all')?.addEventListener('click', () => {
    const firstIdx = rows.findIndex(r => !r.approved && !r.sent && !r.skipped && !r.suppressed);
    if (firstIdx !== -1) openEmailPreview(rows[firstIdx].id, rows, firstIdx);
  });
}

function renderProspectHeaderRow(tbody, group, campaignId, rows, colSpan) {
  const rs = group.rows;
  const notionId = group.notion_id;
  const isSuppressed = rs.some(r => r.suppressed);
  const sentCount = rs.filter(r => r.sent).length;
  const allSent = sentCount === rs.length;
  const partiallySent = sentCount > 0 && sentCount < rs.length;
  const collapsed = state.outboxCollapsed.has(notionId);
  const badge = getProspectGroupBadge(group);

  const tr = document.createElement('tr');
  tr.className = 'outbox-prospect-header' + (isSuppressed ? ' suppressed' : '');
  tr.dataset.notionId = notionId;

  const td = document.createElement('td');
  td.colSpan = colSpan;

  const inner = document.createElement('div');
  inner.className = 'outbox-prospect-header-inner';

  const toggle = document.createElement('span');
  toggle.className = 'outbox-toggle';
  toggle.textContent = collapsed ? '▶' : '▼';

  const name = document.createElement('span');
  name.className = 'outbox-prospect-name';
  name.textContent = group.business_name || '—';

  const email = document.createElement('span');
  email.className = 'outbox-prospect-email';
  email.textContent = group.email || '—';

  const badgeEl = document.createElement('span');
  badgeEl.className = 'outbox-prospect-badge';
  badgeEl.style.color = badge.color;
  badgeEl.style.borderColor = badge.border;
  badgeEl.textContent = badge.text;

  const actions = document.createElement('div');
  actions.className = 'outbox-prospect-actions';

  if (isSuppressed) {
    const btnUnsuppress = document.createElement('button');
    btnUnsuppress.className = 'btn-ob-seq unsuppress';
    btnUnsuppress.textContent = 'Unsuppress';
    btnUnsuppress.addEventListener('click', async e => {
      e.stopPropagation();
      if (!confirm(`Resume sequence for ${group.business_name || 'this prospect'}?`)) return;
      btnUnsuppress.disabled = true;
      try {
        await apiPost({ action: 'outbox_unsuppress_prospect', notion_id: notionId, campaign_id: campaignId });
        rs.forEach(r => { if (!r.sent) r.suppressed = 0; });
        state.outboxRows = rows;
        rerenderOutboxPreserveScroll(rows, campaignId);
      } catch (err) { btnUnsuppress.disabled = false; alert('Error: ' + err.message); }
    });
    actions.appendChild(btnUnsuppress);
  } else if (!allSent) {
    if (!partiallySent) {
      const btnApprove = document.createElement('button');
      btnApprove.className = 'btn-ob-seq approve';
      btnApprove.textContent = 'Approve Sequence';
      btnApprove.addEventListener('click', async e => {
        e.stopPropagation();
        btnApprove.disabled = true;
        try {
          await apiPost({ action: 'outbox_approve_prospect', notion_id: notionId, campaign_id: campaignId });
          rs.forEach(r => { if (!r.sent && !r.skipped && !r.suppressed) r.approved = 1; });
          state.outboxRows = rows;
          rerenderOutboxPreserveScroll(rows, campaignId);
        } catch (err) { btnApprove.disabled = false; alert('Error: ' + err.message); }
      });
      const btnRevoke = document.createElement('button');
      btnRevoke.className = 'btn-ob-seq revoke';
      btnRevoke.textContent = 'Revoke Sequence';
      btnRevoke.addEventListener('click', async e => {
        e.stopPropagation();
        btnRevoke.disabled = true;
        try {
          await apiPost({ action: 'outbox_unapprove_prospect', notion_id: notionId, campaign_id: campaignId });
          rs.forEach(r => { if (!r.sent) r.approved = 0; });
          state.outboxRows = rows;
          rerenderOutboxPreserveScroll(rows, campaignId);
        } catch (err) { btnRevoke.disabled = false; alert('Error: ' + err.message); }
      });
      actions.append(btnApprove, btnRevoke);
    }
    const btnSuppress = document.createElement('button');
    btnSuppress.className = 'btn-ob-seq suppress';
    btnSuppress.textContent = 'Suppress';
    btnSuppress.addEventListener('click', async e => {
      e.stopPropagation();
      if (!confirm(`Stop all remaining emails to ${group.business_name || 'this prospect'}? This cannot be auto-reversed.`)) return;
      btnSuppress.disabled = true;
      try {
        await apiPost({ action: 'outbox_suppress_prospect', notion_id: notionId, campaign_id: campaignId });
        rs.forEach(r => { if (!r.sent) r.suppressed = 1; });
        state.outboxRows = rows;
        rerenderOutboxPreserveScroll(rows, campaignId);
      } catch (err) { btnSuppress.disabled = false; alert('Error: ' + err.message); }
    });
    actions.appendChild(btnSuppress);
  }

  inner.append(toggle, name, email, badgeEl, actions);
  td.appendChild(inner);
  tr.appendChild(td);

  tr.addEventListener('click', e => {
    if (e.target.closest('button')) return;
    if (state.outboxCollapsed.has(notionId)) state.outboxCollapsed.delete(notionId);
    else state.outboxCollapsed.add(notionId);
    rerenderOutboxPreserveScroll(rows, campaignId);
  });

  tbody.appendChild(tr);
  return collapsed;
}

function renderOutboxSubRow(tbody, row, rows, idx, campaignId, hidden) {
  const tr = document.createElement('tr');
  tr.id = 'outbox-row-' + row.id;
  tr.className = 'outbox-seq-row' + (row.suppressed ? ' suppressed' : '');
  tr.dataset.notionId = row.notion_id;
  if (hidden) tr.style.display = 'none';

  const tdSeq = document.createElement('td');
  tdSeq.className = 'outbox-seq-label';
  tdSeq.textContent = outboxSeqLabel(row.seq_num);

  const tdSubj = document.createElement('td');
  tdSubj.className = 'outbox-subject';
  tdSubj.title = row.subject || '';
  tdSubj.textContent = row.subject || '—';

  const tdSched = document.createElement('td');
  tdSched.className = 'muted';
  tdSched.style.fontSize = '.8rem';
  tdSched.textContent = row.scheduled_not_before ? row.scheduled_not_before.slice(0, 16) : '—';

  const tdApproval = document.createElement('td');
  tdApproval.dataset.outboxCol = 'approval';
  renderOutboxApprovalCell(tdApproval, row);

  const tdStatus = document.createElement('td');
  tdStatus.dataset.outboxCol = 'status';
  renderOutboxStatusCell(tdStatus, row);

  const tdActions = document.createElement('td');
  tdActions.dataset.outboxCol = 'actions';
  renderOutboxActionsCell(tdActions, row, rows, idx, campaignId);

  tr.append(tdSeq, tdSubj, tdSched, tdApproval, tdStatus, tdActions);
  tbody.appendChild(tr);
}

function renderOutboxFlatRow(tbody, row, rows, idx, campaignId, rowNum) {
  const tr = document.createElement('tr');
  tr.id = 'outbox-row-' + row.id;

  const tdNum = document.createElement('td');
  tdNum.className = 'muted'; tdNum.textContent = String(rowNum);

  const tdBiz = document.createElement('td');
  tdBiz.textContent = row.business_name || '—';

  const tdEmail = document.createElement('td');
  tdEmail.className = 'muted'; tdEmail.textContent = row.email || '—';

  const tdApproval = document.createElement('td');
  tdApproval.dataset.outboxCol = 'approval';
  renderOutboxApprovalCell(tdApproval, row);

  const tdStatus = document.createElement('td');
  tdStatus.dataset.outboxCol = 'status';
  renderOutboxStatusCell(tdStatus, row);

  const tdSched = document.createElement('td');
  tdSched.className = 'muted';
  tdSched.style.fontSize = '.8rem';
  tdSched.textContent = row.scheduled_not_before ? row.scheduled_not_before.slice(0, 16) : '—';

  const tdActions = document.createElement('td');
  tdActions.dataset.outboxCol = 'actions';
  renderOutboxActionsCell(tdActions, row, rows, idx, campaignId);

  tr.append(tdNum, tdBiz, tdEmail, tdApproval, tdStatus, tdSched, tdActions);
  tbody.appendChild(tr);
}

function renderOutboxRows(rows, campaignId, groups, isGrouped) {
  const tbody = document.getElementById('outbox-tbody');
  if (!tbody) return;
  tbody.innerHTML = '';

  if (!isGrouped) {
    groups.forEach((group, gi) => {
      const row = group.rows[0];
      const idx = rows.indexOf(row);
      renderOutboxFlatRow(tbody, row, rows, idx, campaignId, gi + 1);
    });
    return;
  }

  groups.forEach(group => {
    const collapsed = renderProspectHeaderRow(tbody, group, campaignId, rows, 6);
    group.rows.forEach(row => {
      const idx = rows.indexOf(row);
      renderOutboxSubRow(tbody, row, rows, idx, campaignId, collapsed);
    });
  });
}

function refreshOutboxRowCells(rowId, row, rows, idx, campaignId) {
  const tr = document.getElementById('outbox-row-' + rowId);
  if (!tr) return;
  const approvalTd = tr.querySelector('[data-outbox-col="approval"]');
  const statusTd = tr.querySelector('[data-outbox-col="status"]');
  const actionsTd = tr.querySelector('[data-outbox-col="actions"]');
  if (approvalTd) renderOutboxApprovalCell(approvalTd, row);
  if (statusTd) renderOutboxStatusCell(statusTd, row);
  if (actionsTd) renderOutboxActionsCell(actionsTd, row, rows, idx, campaignId);
}

function renderOutboxApprovalCell(td, row) {
  td.innerHTML = '';
  if (row.suppressed || row.sent || row.skipped) return;
  const span = document.createElement('span');
  span.style.fontSize = '.82rem';
  if (row.approved) {
    span.style.color = '#22c55e';
    span.textContent = '✓ Approved';
  } else {
    span.style.color = 'var(--grey)';
    span.textContent = '○ Pending review';
  }
  td.appendChild(span);
}

function renderOutboxStatusCell(td, row) {
  td.innerHTML = '';
  td.style.fontSize = '.82rem';

  if (row.sent) {
    const s = document.createElement('span');
    s.style.color = '#22c55e'; s.textContent = '✓ Sent';
    td.appendChild(s);
    if (row.sent_at) {
      const d = document.createElement('div');
      d.style.cssText = 'color:var(--muted);font-size:.75rem';
      d.textContent = row.sent_at.slice(0, 16);
      td.appendChild(d);
    }
    return;
  }
  if (row.suppressed) {
    const s = document.createElement('span');
    s.style.cssText = 'color:var(--grey)'; s.textContent = 'Suppressed';
    td.appendChild(s);
    return;
  }
  if (row.send_error) {
    const s = document.createElement('span');
    s.style.color = 'var(--red)'; s.title = row.send_error; s.textContent = '⚠ Error';
    td.appendChild(s); return;
  }
  if (row.skipped) {
    const s = document.createElement('span');
    s.style.cssText = 'color:var(--grey);font-style:italic'; s.textContent = 'Skipped';
    td.appendChild(s);
    if (row.skip_reason) {
      const d = document.createElement('div');
      d.style.cssText = 'font-size:.75rem;color:var(--muted)'; d.textContent = row.skip_reason;
      td.appendChild(d);
    }
    return;
  }
  if (row.scheduled_not_before && new Date(row.scheduled_not_before) > new Date()) {
    const s = document.createElement('span');
    s.style.color = 'var(--muted)';
    s.textContent = 'Embargoed until ' + row.scheduled_not_before.slice(0, 10);
    td.appendChild(s); return;
  }
  const s = document.createElement('span');
  s.style.color = row.approved ? '#22c55e' : 'var(--amber)';
  s.textContent  = row.approved ? 'Ready to send' : 'Awaiting approval';
  td.appendChild(s);
}

function renderOutboxActionsCell(td, row, rows, idx, campaignId) {
  td.innerHTML = '';
  const wrap = document.createElement('div');
  wrap.className = 'outbox-cell-actions';

  if (row.suppressed && !row.sent) {
    ['Preview', 'Revoke', 'Skip'].forEach(label => {
      const btn = document.createElement('button');
      btn.className = 'btn-ob ' + label.toLowerCase();
      btn.textContent = label;
      btn.disabled = true;
      wrap.appendChild(btn);
    });
    td.appendChild(wrap);
    return;
  }

  if (!row.sent && !row.skipped) {
    const btnPreview = document.createElement('button');
    btnPreview.className = 'btn-ob preview'; btnPreview.textContent = 'Preview';
    btnPreview.addEventListener('click', e => { e.stopPropagation(); openEmailPreview(row.id, rows, idx); });
    wrap.appendChild(btnPreview);

    if (!row.approved) {
      const btnApprove = document.createElement('button');
      btnApprove.className = 'btn-ob approve'; btnApprove.textContent = 'Approve';
      btnApprove.addEventListener('click', async e => {
        e.stopPropagation(); btnApprove.disabled = true;
        try {
          await apiPost({ action: 'outbox_approve', id: row.id });
          row.approved = 1;
          refreshOutboxRowCells(row.id, row, rows, idx, campaignId);
          updateOutboxSummaryBar(rows);
        } catch (err) { btnApprove.disabled = false; alert('Error: ' + err.message); }
      });
      wrap.appendChild(btnApprove);
    } else {
      const btnRevoke = document.createElement('button');
      btnRevoke.className = 'btn-ob revoke'; btnRevoke.textContent = 'Revoke';
      btnRevoke.addEventListener('click', async e => {
        e.stopPropagation(); btnRevoke.disabled = true;
        try {
          await apiPost({ action: 'outbox_unapprove', id: row.id });
          row.approved = 0;
          refreshOutboxRowCells(row.id, row, rows, idx, campaignId);
          updateOutboxSummaryBar(rows);
        } catch (err) { btnRevoke.disabled = false; alert('Error: ' + err.message); }
      });
      wrap.appendChild(btnRevoke);
    }

    const btnSkip = document.createElement('button');
    btnSkip.className = 'btn-ob skip'; btnSkip.textContent = 'Skip';
    btnSkip.addEventListener('click', async e => {
      e.stopPropagation();
      const reason = prompt('Reason for skipping (optional):');
      if (reason === null) return;
      btnSkip.disabled = true;
      try {
        await apiPost({ action: 'outbox_skip', id: row.id, reason: reason || null });
        row.skipped = 1; row.skip_reason = reason || null; row.approved = 0;
        refreshOutboxRowCells(row.id, row, rows, idx, campaignId);
        updateOutboxSummaryBar(rows);
      } catch (err) { btnSkip.disabled = false; alert('Error: ' + err.message); }
    });
    wrap.appendChild(btnSkip);

  } else if (row.sent) {
    const btnView = document.createElement('button');
    btnView.className = 'btn-ob preview'; btnView.textContent = 'View';
    btnView.addEventListener('click', e => { e.stopPropagation(); openEmailPreview(row.id, rows, idx); });
    wrap.appendChild(btnView);
  } else if (row.skipped) {
    const btnUnskip = document.createElement('button');
    btnUnskip.className = 'btn-ob unskip'; btnUnskip.textContent = 'Unskip';
    btnUnskip.addEventListener('click', async e => {
      e.stopPropagation(); btnUnskip.disabled = true;
      try {
        await apiPost({ action: 'outbox_unskip', id: row.id });
        row.skipped = 0; row.skip_reason = null;
        refreshOutboxRowCells(row.id, row, rows, idx, campaignId);
        updateOutboxSummaryBar(rows);
      } catch (err) { btnUnskip.disabled = false; alert('Error: ' + err.message); }
    });
    wrap.appendChild(btnUnskip);
  }

  td.appendChild(wrap);
}

function updateOutboxSummaryBar(rows) {
  const bar = document.getElementById('outbox-summary-bar');
  if (!bar) return;
  const s = computeOutboxSummaryStats(rows);
  const strong = bar.querySelector('strong');
  const line2 = bar.querySelector('.summ-line2');
  if (strong) strong.textContent = s.prospectCount;
  if (line2) {
    line2.textContent = `${s.totalEmails} emails — ${s.sent} sent · ${s.embargoed} embargoed · ${s.pending} awaiting approval · ${s.skipped} skipped · ${s.suppressed} suppressed`;
  }
  const hasPending = rows.some(r => !r.approved && !r.sent && !r.skipped && !r.suppressed);
  const btnR = bar.querySelector('#btn-review-all');
  const btnA = bar.querySelector('#btn-approve-all');
  if (btnR) btnR.disabled = !hasPending;
  if (btnA) btnA.disabled = !hasPending;
}

// ── Email preview modal ───────────────────────────────────────────────────────
async function openEmailPreview(rowId, rows, idx) {
  const overlay = document.getElementById('email-modal-overlay');
  const bodyEl  = document.getElementById('email-modal-body');
  bodyEl.innerHTML = '<div class="state-msg" style="padding:2rem 0">Loading…</div>';
  document.getElementById('email-approval-btns').innerHTML = '';
  document.getElementById('btn-edit-subject').classList.remove('editing');
  document.getElementById('btn-edit-body').classList.remove('editing');
  overlay.classList.add('open');

  try {
    const { data: fullRow } = await apiFetch({ action: 'outbox_record', id: rowId });
    renderEmailPreviewContent(fullRow, rows, idx);
  } catch (err) {
    bodyEl.innerHTML = `<p style="color:var(--red);padding:1rem">${escHtml(err.message)}</p>`;
  }
}

function renderEmailPreviewContent(row, rows, idx) {
  const titleEl = document.getElementById('email-modal-title');
  const seqPart = outboxSeqLabel(row.seq_num);
  if (titleEl) titleEl.textContent = row.sent
    ? `${seqPart} — ✓ Sent${row.sent_at ? ' ' + row.sent_at.slice(0, 10) : ''}`
    : row.suppressed ? `${seqPart} — Suppressed`
    : row.approved ? `${seqPart} — ✓ Approved` : `${seqPart} — Awaiting Approval`;

  const bodyEl = document.getElementById('email-modal-body');
  bodyEl.innerHTML = '';

  const envelope = document.createElement('div');
  envelope.className = 'email-envelope';

  // Header pane
  const hPane = document.createElement('div');
  hPane.className = 'email-header-pane';

  function makeHRow(label, value, id) {
    const div = document.createElement('div');
    div.className = 'email-header-row';
    if (id) div.id = id;
    const lbl = document.createElement('span');
    lbl.className = 'email-header-label'; lbl.textContent = label;
    const val = document.createElement('span');
    val.className = 'email-header-value'; val.textContent = value;
    div.append(lbl, val);
    return div;
  }

  hPane.appendChild(makeHRow('From:', 'NeoBookworm <neobookworm@icloud.com>'));
  hPane.appendChild(makeHRow('To:', row.email || ''));

  const subjRow = makeHRow('Subject:', row.subject || '', 'email-subject-row');
  subjRow.querySelector('.email-header-value').id = 'email-subject-val';
  hPane.appendChild(subjRow);

  // Body pane
  const bPane = document.createElement('div');
  bPane.className = 'email-body-pane';
  bPane.id = 'email-body-pane';
  linkifyIntoContainer(row.body || '', bPane);

  envelope.append(hPane, bPane);
  bodyEl.appendChild(envelope);

  wireEmailFooter(row, rows, idx);
}

function linkifyIntoContainer(text, container) {
  container.innerHTML = '';
  const URL_RE = /https?:\/\/\S+/g;
  let lastIdx = 0, match;
  while ((match = URL_RE.exec(text)) !== null) {
    if (match.index > lastIdx)
      container.appendChild(document.createTextNode(text.slice(lastIdx, match.index)));
    const a = document.createElement('a');
    a.href = match[0]; a.target = '_blank'; a.rel = 'noopener noreferrer';
    a.textContent = match[0];
    container.appendChild(a);
    lastIdx = match.index + match[0].length;
  }
  if (lastIdx < text.length)
    container.appendChild(document.createTextNode(text.slice(lastIdx)));
}

function wireEmailFooter(row, rows, idx) {
  const btnSubj = document.getElementById('btn-edit-subject');
  const btnBody = document.getElementById('btn-edit-body');
  if (row.sent || row.suppressed) {
    if (btnSubj) { btnSubj.style.display = 'none'; }
    if (btnBody) { btnBody.style.display = 'none'; }
    document.getElementById('email-approval-btns').innerHTML = '';
    return;
  }
  if (btnSubj) { btnSubj.style.display = ''; btnSubj.classList.remove('editing'); btnSubj.textContent = 'Edit subject'; btnSubj.onclick = () => startSubjectEdit(row, rows, idx); }
  if (btnBody) { btnBody.style.display = ''; btnBody.classList.remove('editing');  btnBody.textContent = 'Edit body';    btnBody.onclick = () => startBodyEdit(row, rows, idx); }
  renderEmailApprovalBtns(row, rows, idx);
}

function renderEmailApprovalBtns(row, rows, idx) {
  const zone = document.getElementById('email-approval-btns');
  if (!zone) return;
  zone.innerHTML = '';

  if (!row.approved) {
    const btnApprove = document.createElement('button');
    btnApprove.className = 'btn-em-approve'; btnApprove.textContent = 'Approve';
    btnApprove.addEventListener('click', async () => {
      btnApprove.disabled = true;
      try {
        await apiPost({ action: 'outbox_approve', id: row.id });
        row.approved = 1;
        const sr = state.outboxRows.find(r => r.id === row.id);
        if (sr) sr.approved = 1;
        refreshOutboxRow(row.id, rows, idx);
        updateOutboxSummaryBar(state.outboxRows);
        const t = document.getElementById('email-modal-title');
        if (t) t.textContent = `${outboxSeqLabel(row.seq_num)} — ✓ Approved`;
        renderEmailApprovalBtns(row, rows, idx);
      } catch (err) { btnApprove.disabled = false; alert('Error: ' + err.message); }
    });

    const btnNext = document.createElement('button');
    btnNext.className = 'btn-em-approve-next'; btnNext.textContent = 'Approve & Next';
    btnNext.addEventListener('click', async () => {
      btnNext.disabled = true;
      try {
        await apiPost({ action: 'outbox_approve', id: row.id });
        row.approved = 1;
        const sr = state.outboxRows.find(r => r.id === row.id);
        if (sr) sr.approved = 1;
        refreshOutboxRow(row.id, rows, idx);
        updateOutboxSummaryBar(state.outboxRows);
        const nextIdx = rows.findIndex((r, i) => i > idx && !r.approved && !r.sent && !r.skipped && !r.suppressed);
        if (nextIdx !== -1) {
          openEmailPreview(rows[nextIdx].id, rows, nextIdx);
        } else {
          document.getElementById('email-modal-body').innerHTML =
            '<div class="state-msg" style="color:#22c55e;padding:2rem">All emails reviewed ✓</div>';
          document.getElementById('email-approval-btns').innerHTML = '';
          setTimeout(closeEmailModal, 1800);
        }
      } catch (err) { btnNext.disabled = false; alert('Error: ' + err.message); }
    });

    zone.append(btnApprove, btnNext);
  } else {
    const approved = document.createElement('button');
    approved.className = 'btn-em-approved'; approved.textContent = '✓ Approved'; approved.disabled = true;

    const btnRevoke = document.createElement('button');
    btnRevoke.className = 'btn-em-revoke'; btnRevoke.textContent = 'Revoke Approval';
    btnRevoke.addEventListener('click', async () => {
      btnRevoke.disabled = true;
      try {
        await apiPost({ action: 'outbox_unapprove', id: row.id });
        row.approved = 0;
        const sr = state.outboxRows.find(r => r.id === row.id);
        if (sr) sr.approved = 0;
        refreshOutboxRow(row.id, rows, idx);
        updateOutboxSummaryBar(state.outboxRows);
        const t = document.getElementById('email-modal-title');
        if (t) t.textContent = `${outboxSeqLabel(row.seq_num)} — Awaiting Approval`;
        renderEmailApprovalBtns(row, rows, idx);
      } catch (err) { btnRevoke.disabled = false; alert('Error: ' + err.message); }
    });

    zone.append(approved, btnRevoke);
  }
}

function refreshOutboxRow(rowId, rows, idx) {
  const row = rows[idx];
  if (!row) return;
  refreshOutboxRowCells(rowId, row, rows, idx, state.outboxCampaignId);
}

function startSubjectEdit(row, rows, idx) {
  const btnSubj = document.getElementById('btn-edit-subject');
  if (!btnSubj) return;
  btnSubj.classList.add('editing');
  const subjRow = document.getElementById('email-subject-row');
  if (!subjRow) return;

  const lbl = subjRow.querySelector('.email-header-label');
  subjRow.innerHTML = '';
  if (lbl) subjRow.appendChild(lbl);

  const wrap = document.createElement('div');
  wrap.className = 'subject-edit-row';
  const input     = document.createElement('input');  input.type = 'text'; input.value = row.subject || '';
  const btnSave   = document.createElement('button'); btnSave.className = 'btn-ed-save';   btnSave.textContent = 'Save';
  const btnCancel = document.createElement('button'); btnCancel.className = 'btn-ed-cancel'; btnCancel.textContent = 'Cancel';
  wrap.append(input, btnSave, btnCancel);
  subjRow.appendChild(wrap);

  const restore = () => {
    subjRow.innerHTML = '';
    const l2 = document.createElement('span'); l2.className = 'email-header-label'; l2.textContent = 'Subject:';
    const v2 = document.createElement('span'); v2.className = 'email-header-value'; v2.id = 'email-subject-val'; v2.textContent = row.subject || '';
    subjRow.append(l2, v2);
    btnSubj.classList.remove('editing');
    btnSubj.onclick = () => startSubjectEdit(row, rows, idx);
  };

  btnCancel.addEventListener('click', restore);
  btnSave.addEventListener('click', async () => {
    const val = input.value.trim();
    if (!val) return;
    btnSave.disabled = true;
    try {
      await apiPost({ action: 'outbox_edit', id: row.id, fields: { subject: val } });
      row.subject = val;
      const sr = state.outboxRows.find(r => r.id === row.id);
      if (sr) sr.subject = val;
      restore();
    } catch (err) { btnSave.disabled = false; alert('Error: ' + err.message); }
  });
}

function startBodyEdit(row, rows, idx) {
  const btnBody = document.getElementById('btn-edit-body');
  if (!btnBody) return;
  btnBody.classList.add('editing');
  const bPane = document.getElementById('email-body-pane');
  if (!bPane) return;

  const ta = document.createElement('textarea');
  ta.className = 'email-body-edit'; ta.value = row.body || ''; ta.rows = 14;

  const bar = document.createElement('div');
  bar.style.cssText = 'padding:.5rem 1rem;display:flex;gap:.5rem;background:#f0f0f0;border-top:1px solid #ddd';
  const btnSave   = document.createElement('button'); btnSave.className = 'btn-ed-save';   btnSave.textContent = 'Save';
  const btnCancel = document.createElement('button'); btnCancel.className = 'btn-ed-cancel'; btnCancel.textContent = 'Cancel';
  bar.append(btnSave, btnCancel);

  bPane.innerHTML = ''; bPane.style.padding = '0';
  bPane.append(ta, bar);

  const restore = (body) => {
    bPane.innerHTML = ''; bPane.style.padding = '';
    linkifyIntoContainer(body, bPane);
    btnBody.classList.remove('editing');
    btnBody.onclick = () => startBodyEdit(row, rows, idx);
  };

  btnCancel.addEventListener('click', () => restore(row.body || ''));
  btnSave.addEventListener('click', async () => {
    btnSave.disabled = true;
    try {
      await apiPost({ action: 'outbox_edit', id: row.id, fields: { body: ta.value } });
      row.body = ta.value;
      const sr = state.outboxRows.find(r => r.id === row.id);
      if (sr) sr.body = ta.value;
      restore(ta.value);
    } catch (err) { btnSave.disabled = false; alert('Error: ' + err.message); }
  });
}

function closeEmailModal() {
  document.getElementById('email-modal-overlay').classList.remove('open');
}

// ── Shared delete helper ──────────────────────────────────────────────────────
function wireDeleteButton({ btnId, action, recordId, isUnhandled, unhandledStateKey, badgeFn, onDeleted }) {
  const btn = document.getElementById(btnId);
  if (!btn) return;

  btn.addEventListener('click', () => {
    const parent = btn.parentElement;
    btn.remove();

    const confirm = document.createElement('div');
    confirm.className = 'delete-confirm';
    confirm.innerHTML = `
      <span>Delete this record?</span>
      <button class="btn-confirm-yes">Yes, delete</button>
      <button class="btn-confirm-no">Cancel</button>
    `;
    parent.appendChild(confirm);

    confirm.querySelector('.btn-confirm-no').addEventListener('click', () => {
      confirm.remove();
      parent.appendChild(btn);
    });

    confirm.querySelector('.btn-confirm-yes').addEventListener('click', async () => {
      const yesBtn = confirm.querySelector('.btn-confirm-yes');
      yesBtn.disabled = true; yesBtn.textContent = 'Deleting…';
      try {
        await apiPost({ action, id: recordId });
        if (isUnhandled && unhandledStateKey && badgeFn) {
          state[unhandledStateKey] = Math.max(0, state[unhandledStateKey] - 1);
          badgeFn();
        }
        closeModal();
        onDeleted();
      } catch (err) {
        confirm.remove();
        parent.appendChild(btn);
        const errEl = parent.querySelector('.save-status');
        if (errEl) { errEl.textContent = 'Delete failed: ' + err.message; errEl.className = 'save-status err'; }
      }
    });
  });
}

// ── Modal close ───────────────────────────────────────────────────────────────
document.getElementById('modal-close').addEventListener('click', closeModal);
document.getElementById('modal-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
});
document.getElementById('email-modal-close').addEventListener('click', closeEmailModal);
document.getElementById('email-modal-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('email-modal-overlay')) closeEmailModal();
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (document.getElementById('email-modal-overlay').classList.contains('open')) closeEmailModal();
    else closeModal();
  }
});

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

// ── Back button ───────────────────────────────────────────────────────────────
document.getElementById('btn-back').addEventListener('click', () => {
  if (state.tab === 'prospects' && state.view === 'list') renderSummary(state.summaryData);
  if (state.tab === 'campaigns' && state.campView === 'detail') loadCampaignsList();
  if (state.tab === 'clients'   && state.clientsView === 'detail') {
    state.clientsView = 'list';
    loadClientsList({ soft: true });
  }
});

// ── Breadcrumb ────────────────────────────────────────────────────────────────
function setBreadcrumb(items) {
  const el = document.getElementById('breadcrumb');
  el.innerHTML = items.map((item, i) => {
    const isLast = i === items.length - 1;
    if (isLast) return `<span class="active">${escHtml(item.label)}</span>`;
    return `<span class="link" style="cursor:pointer;color:var(--muted)" data-idx="${i}">${escHtml(item.label)}</span><span class="sep">/</span>`;
  }).join('');
  el.querySelectorAll('.link').forEach(link => {
    const idx = parseInt(link.dataset.idx, 10);
    if (items[idx]?.action) link.addEventListener('click', items[idx].action);
  });
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function escAttr(str) { return String(str || '').replace(/"/g, '&quot;'); }

// ── Clients tab ───────────────────────────────────────────────────────────────

const STAGE_LABELS = {
  acknowledged:     'Acknowledged',
  researching:      'Researching',
  building:         'Building',
  reviewing:        'Reviewing',
  review_delivered: 'Review delivered',
  preview_ready:    'Preview ready',
  revisions:        'Revisions',
  awaiting_payment: 'Awaiting payment',
  preparing_live:   'Preparing live',
