    case 'status':
      return `<input type="search" class="col-filter" data-col="q_status" placeholder="Filter…" value="${escAttr(cf.q_status)}">`;
    case 'last_email_sent':
      return `<select class="col-filter" data-col="emailed_filter">
        <option value="" ${cf.emailed_filter === '' ? 'selected' : ''}>Any</option>
        <option value="emailed" ${cf.emailed_filter === 'emailed' ? 'selected' : ''}>Emailed</option>
        <option value="never" ${cf.emailed_filter === 'never' ? 'selected' : ''}>Never</option>
      </select>`;
    default:
      return '';
  }
}

function outboxFilterCell(col, cf) {
  switch (col) {
    case 'business_name':
      return `<input type="search" class="col-filter" data-col="q_business" placeholder="Filter…" value="${escAttr(cf.q_business)}">`;
    case 'email':
      return `<input type="search" class="col-filter" data-col="q_email" placeholder="Filter…" value="${escAttr(cf.q_email)}">`;
    case 'subject':
