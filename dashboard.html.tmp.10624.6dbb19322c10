];

function clientHumanTime(isoStr) {
  if (!isoStr) return '—';
  const norm  = isoStr.includes('T') ? isoStr : isoStr.replace(' ', 'T') + 'Z';
  const diffMs = Date.now() - new Date(norm).getTime();
  const s = Math.floor(diffMs / 1000);
  if (s < 90)    return 'just now';
  if (s < 3600)  return `${Math.floor(s / 60)}m ago`;
  if (s < 7200)  return '1h ago';
  if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
  const d = Math.floor(s / 86400);
  return d === 1 ? '1d ago' : `${d}d ago`;
}

/** Long UK date for stage timestamps, e.g. "26 May 2026". */
function formatUkDate(isoStr) {
  if (!isoStr) return '—';
  try {
    const norm = isoStr.includes('T') ? isoStr : isoStr.replace(' ', 'T') + 'Z';
    return new Date(norm).toLocaleDateString('en-GB', {
      day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Europe/London',
    });
  } catch {
    return isoStr;
  }
}

/** Value for &lt;input type="date"&gt; — only when next_action_by is stored as YYYY-MM-DD. */
function parseIsoDateForInput(val) {
  if (!val) return '';
  const m = String(val).match(/^(\d{4}-\d{2}-\d{2})/);
  return m ? m[1] : '';
}

function syncStageDateUi(stage) {
  const sinceWrap  = document.getElementById('stage-since-wrap');
  const actionWrap = document.getElementById('next-action-wrap');
  if (!sinceWrap || !actionWrap) return;
  const isAck = stage === 'acknowledged';
  sinceWrap.style.display  = isAck ? '' : 'none';
  actionWrap.style.display = isAck ? 'none' : 'inline-flex';
}

// ── Clients: list view ────────────────────────────────────────────────────────

async function loadClientsList({ soft = false } = {}) {
  state.clientsView = 'list';
  setBreadcrumb([{ label: 'Clients' }]);
  document.getElementById('btn-back').style.display = 'none';
  const main = document.getElementById('main-content');
  if (!soft) main.innerHTML = '<div class="state-msg">Loading…</div>';
  try {
    const data = await apiFetch({
      action:       'client_list',
      stage_filter: state.clientsStageFilter,
      q_search:     state.clientsSearch,
      page:         state.clientsPage,
    });
    renderClientsList(data);
  } catch (err) {
    main.innerHTML = `<div class="state-msg">Error loading clients: ${escHtml(err.message)}</div>`;
  }
}

function renderClientsList({ data: rows, total, page, pageSize }) {
  const main  = document.getElementById('main-content');
  const start = (page - 1) * pageSize + 1;
  const end   = Math.min(page * pageSize, total);

  const stageOpts = [
    { val: 'active', label: 'Active (all except dropped out)' },
    { val: 'all',    label: 'All stages' },
    ...ALL_CLIENT_STAGES.map(s => ({ val: s, label: STAGE_LABELS[s] })),
  ].map(o =>
    `<option value="${escAttr(o.val)}"${state.clientsStageFilter === o.val ? ' selected' : ''}>${escHtml(o.label)}</option>`
  ).join('');

  const tableRows = rows.length === 0
    ? `<tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--muted)">No clients yet.</td></tr>`
    : rows.map(row => {
        const stuck      = STUCK_STAGES.has(row.stage) && (row.days_in_stage || 0) > 14;
        const stageColor = STAGE_COLORS[row.stage]  || 'var(--grey)';
        const stageLabel = STAGE_LABELS[row.stage]  || row.stage;
        const biz        = row.business_name || row.contact_name || row.email;
        const sub        = row.contact_name && row.contact_name !== biz ? row.contact_name : null;
        const portalUrl  = `/c/${encodeURIComponent(row.slug)}/`;
        const nextAction = row.next_action_by ? row.next_action_by.substring(0, 10) : '—';
        const days       = row.days_in_stage != null ? row.days_in_stage : '—';
        return `<tr class="${stuck ? 'stuck-row' : ''}" data-slug="${escAttr(row.slug)}" style="cursor:pointer">
          <td>
            <strong>${escHtml(biz)}</strong>
            ${sub ? `<br><span style="font-size:.78rem;color:var(--muted)">${escHtml(sub)}</span>` : ''}
            <br><span style="font-size:.75rem;color:var(--muted)">${escHtml(row.email)}</span>
          </td>
          <td><span style="display:inline-block;padding:.1rem .45rem;border-radius:4px;font-size:.72rem;font-weight:700;background:rgba(75,156,245,.18);color:var(--blue)">${escHtml(row.journey || '—')}</span></td>
          <td><span style="display:inline-block;padding:.12rem .5rem;border-radius:20px;font-size:.72rem;font-weight:600;border:1px solid ${stageColor};color:${stageColor};white-space:nowrap">${escHtml(stageLabel)}</span></td>
          <td${stuck ? ' style="color:var(--red);font-weight:600"' : ' class="muted"'}>${escHtml(String(days))}${stuck ? ' ⚠' : ''}</td>
          <td class="muted">${escHtml(clientHumanTime(row.last_email_at))}</td>
          <td class="muted" style="font-size:.82rem">${escHtml(nextAction)}</td>
          <td><a href="${escAttr(portalUrl)}" target="_blank" rel="noopener" style="color:var(--amber);font-size:.9rem;text-decoration:none" onclick="event.stopPropagation()">↗</a></td>
          <td>
            <button class="filter-btn" style="font-size:.78rem;padding:.28rem .7rem;border-color:var(--amber);color:var(--amber)"
                    data-slug="${escAttr(row.slug)}" onclick="event.stopPropagation();loadClientDetail(this.dataset.slug)">View</button>
          </td>
        </tr>`;
      }).join('');

  main.innerHTML = `
    <div class="list-header">
      <h2>Clients <span class="count-tag">${total.toLocaleString()} total</span></h2>
      <div class="list-controls">
        <input type="text" id="clients-search" placeholder="Search business / email…"
               style="padding:.5rem .9rem;border:1px solid var(--border);border-radius:8px;background:var(--navy-card);color:var(--white);font-size:.9rem;width:min(220px,100%);outline:none"
               value="${escAttr(state.clientsSearch)}">
        <select id="clients-stage-filter"
                style="padding:.43rem .7rem;border:1px solid var(--border);border-radius:7px;background:var(--navy-card);color:var(--white);font-size:.83rem;outline:none;cursor:pointer">
          ${stageOpts}
        </select>
        ${state.clientsSearch || state.clientsStageFilter !== 'active'
          ? `<button class="btn-clear-filters" id="clients-clear-filters">Clear filters</button>` : ''}
      </div>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Business / Contact</th>
            <th>Journey</th>
            <th>Stage</th>
            <th>Days</th>
            <th>Last email</th>
            <th>Next action by</th>
            <th>Portal</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="clients-tbody">${tableRows}</tbody>
      </table>
    </div>
    ${total > pageSize ? `
    <div class="pagination">
      <button id="clients-prev" ${page <= 1 ? 'disabled' : ''}>← Prev</button>
      <span>${start}–${end} of ${total}</span>
      <button id="clients-next" ${end >= total ? 'disabled' : ''}>Next →</button>
    </div>` : ''}
  `;

  // Wire search input
  const searchEl = document.getElementById('clients-search');
  searchEl?.addEventListener('input', () => {
    clearTimeout(state.clientsFilterTimer);
    state.clientsFilterTimer = setTimeout(() => {
      state.clientsSearch = searchEl.value;
      state.clientsPage   = 1;
      loadClientsList({ soft: true });
    }, 350);
  });

  // Wire stage filter select
  document.getElementById('clients-stage-filter')?.addEventListener('change', e => {
    state.clientsStageFilter = e.target.value;
    state.clientsPage        = 1;
    loadClientsList({ soft: true });
  });

  // Wire clear filters
  document.getElementById('clients-clear-filters')?.addEventListener('click', () => {
    state.clientsSearch      = '';
    state.clientsStageFilter = 'active';
    state.clientsPage        = 1;
    loadClientsList({ soft: true });
  });

  // Wire row click → detail
  document.querySelectorAll('#clients-tbody tr[data-slug]').forEach(tr => {
    tr.addEventListener('click', () => loadClientDetail(tr.dataset.slug));
  });

  // Wire pagination
  document.getElementById('clients-prev')?.addEventListener('click', () => {
    state.clientsPage = Math.max(1, state.clientsPage - 1);
    loadClientsList();
  });
  document.getElementById('clients-next')?.addEventListener('click', () => {
    state.clientsPage++;
    loadClientsList();
  });
}

// ── Clients: detail view ──────────────────────────────────────────────────────

async function loadClientDetail(slug) {
  state.clientsView = 'detail';
  state.clientsSlug = slug;
  setBreadcrumb([
    { label: 'Clients', action: () => { state.clientsView = 'list'; loadClientsList({ soft: true }); } },
    { label: slug },
  ]);
  document.getElementById('btn-back').style.display = '';
  const main = document.getElementById('main-content');
  main.innerHTML = '<div class="state-msg">Loading…</div>';
  try {
    const data = await apiFetch({ action: 'client_detail', slug });
    renderClientDetail(data.data, data.email_log, data.change_requests || []);
  } catch (err) {
    main.innerHTML = `<div class="state-msg">Error: ${escHtml(err.message)}</div>`;
  }
}

function renderClientDetail(c, emailLog) {
  const main        = document.getElementById('main-content');
  const portalUrl   = `/c/${encodeURIComponent(c.slug)}/`;
  const stageColor  = STAGE_COLORS[c.stage]  || 'var(--grey)';
  const stageLabel  = STAGE_LABELS[c.stage]  || c.stage;
  const biz         = c.business_name || c.contact_name || c.email;
  const gmailSub    = encodeURIComponent(`${c.business_name || c.contact_name || ''} — your NeoBookworm website`);
  const gmailUrl    = `https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(c.email)}&su=${gmailSub}`;

  const stageSelectOpts = ALL_CLIENT_STAGES.map(s =>
    `<option value="${escAttr(s)}"${c.stage === s ? ' selected' : ''}>${escHtml(STAGE_LABELS[s])}</option>`
  ).join('');

  const templateOpts = CLIENT_TEMPLATE_GROUPS.map(g =>
    `<optgroup label="${escHtml(g.label)}">${
      g.ids.map(id => `<option value="${escAttr(id)}">${escHtml(CLIENT_TEMPLATE_LABELS[id] || id)}</option>`).join('')
    }</optgroup>`
  ).join('');

  const emailRows = emailLog.length === 0
    ? `<li style="padding:.65rem 0;color:var(--muted);font-size:.875rem">No emails sent yet.</li>`
    : emailLog.map(row => {
        const failed = row.status === 'failed'
          ? `<span style="color:var(--red);font-size:.72rem;margin-left:.3rem">(failed)</span>` : '';
        const rowId   = escAttr(String(row.id || ''));
        const rowSlug = escAttr(c.slug || '');
        return `<li style="padding:.65rem 0;border-bottom:1px solid var(--border)">
          <div style="display:flex;gap:.75rem;align-items:baseline;flex-wrap:wrap">
            <span style="color:var(--amber);font-size:.72rem;flex-shrink:0;font-weight:600">${escHtml(row.template || '')}</span>
            <span style="flex:1;min-width:0;font-size:.85rem">${escHtml(row.subject || '')}${failed}</span>
            <span style="color:var(--muted);font-size:.78rem;white-space:nowrap">${escHtml(clientHumanTime(row.sent_at))}</span>
            <button
              data-log-id="${rowId}"
              data-log-slug="${rowSlug}"
              class="btn-delete-email"
              title="Delete this email from history"
              style="background:none;border:none;color:var(--red);font-size:.85rem;cursor:pointer;padding:0 .2rem;opacity:0.6;flex-shrink:0"
              aria-label="Delete email from history">✕</button>
          </div>
        </li>`;
      }).join('');

  const fieldRow = (field, label, val) => `
    <div style="margin-bottom:.5rem">
      <label style="display:block;color:var(--muted);font-size:.78rem;margin-bottom:.2rem">${label}</label>
      <div style="display:flex;gap:.35rem;align-items:center">
        <input type="text" id="field-${field}" value="${escAttr(val || '')}"
               style="flex:1;padding:.38rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--navy);color:var(--white);font-size:.83rem;outline:none;min-width:0">
        ${val ? `<a href="${escAttr(val)}" target="_blank" rel="noopener" style="color:var(--amber);font-size:.82rem;padding:.38rem .35rem;flex-shrink:0;text-decoration:none">↗</a>` : ''}
      </div>
    </div>`;

  const ackDate      = formatUkDate(c.stage_changed_at || c.created_at);
  const isAckStage   = c.stage === 'acknowledged';
  const deliverByIso = parseIsoDateForInput(c.next_action_by);
  const deliverByHint = !isAckStage && c.next_action_by && !deliverByIso
    ? `<p id="deliver-by-hint" style="margin:.5rem 0 0;font-size:.78rem;color:var(--muted)">Portal deliver-by: ${escHtml(c.next_action_by)}</p>`
    : '';

  main.innerHTML = `
    <div style="margin-bottom:1.5rem">
      <h2 style="font-size:1.25rem;font-weight:700;display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.35rem">
        ${escHtml(biz)}
        <span style="display:inline-block;padding:.1rem .45rem;border-radius:4px;font-size:.72rem;font-weight:700;background:rgba(75,156,245,.18);color:var(--blue)">${escHtml(c.journey || '—')}</span>
        <span style="display:inline-block;padding:.12rem .5rem;border-radius:20px;font-size:.72rem;font-weight:600;border:1px solid ${stageColor};color:${stageColor}">${escHtml(stageLabel)}</span>
      </h2>
      <p style="color:var(--muted);font-size:.85rem">
        ${c.contact_name ? escHtml(c.contact_name) + ' · ' : ''}${escHtml(c.email)} · Created ${escHtml(clientHumanTime(c.created_at))}
      </p>
    </div>

    <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem">
      <a href="${escAttr(portalUrl)}" target="_blank" rel="noopener"
         style="display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.1rem;background:var(--navy-card);border:1px solid var(--amber);border-radius:7px;color:var(--amber);font-size:.875rem;font-weight:600;text-decoration:none">
        Open portal ↗
      </a>
      <a href="${escAttr(gmailUrl)}" target="_blank" rel="noopener"
         style="display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1.1rem;background:var(--navy-card);border:1px solid var(--border);border-radius:7px;color:var(--muted);font-size:.875rem;text-decoration:none">
        Send personal note (Gmail) ↗
      </a>
    </div>

    <!-- Portal preview (collapsible iframe) -->
    <div style="margin-bottom:1.5rem">
      <button id="toggle-portal-iframe"
              style="background:none;border:none;color:var(--amber);font-size:.82rem;cursor:pointer;padding:0;text-decoration:underline">
        Show portal preview ↓
      </button>
      <div id="portal-iframe-wrap" style="display:none;margin-top:.75rem;border:1px solid var(--border);border-radius:8px;overflow:hidden">
        <iframe id="portal-iframe" data-portal-src="${escAttr(portalUrl)}"
                style="width:100%;height:520px;border:none;display:block;background:var(--navy)"
                title="Client portal preview"></iframe>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;margin-bottom:1.5rem">

      <!-- Stage management -->
      <div style="background:var(--navy-card);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem;grid-column:1/-1">
        <div class="section-label" style="margin:0 0 .75rem">Stage</div>
        <div style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap">
          <select id="stage-select"
                  style="padding:.43rem .7rem;border:1px solid var(--border);border-radius:7px;background:var(--navy);color:var(--white);font-size:.875rem;outline:none;flex:1;min-width:160px">
            ${stageSelectOpts}
          </select>
          <span id="stage-since-wrap" class="stage-since"
                style="color:var(--muted);font-size:.875rem;white-space:nowrap${isAckStage ? '' : ';display:none'}">
            Acknowledged on ${escHtml(ackDate)}
          </span>
          <span id="next-action-wrap"
                style="display:${isAckStage ? 'none' : 'inline-flex'};align-items:center;gap:.35rem;flex-wrap:wrap">
            <label for="next-action-input" style="color:var(--muted);font-size:.78rem;white-space:nowrap">Deliver by</label>
            <input type="date" id="next-action-input"
                   value="${escAttr(deliverByIso)}"
                   title="Deliver-by date (shown on portal and in emails)"
                   style="padding:.43rem .65rem;border:1px solid var(--border);border-radius:7px;background:var(--navy);color:var(--white);font-size:.875rem;outline:none">
          </span>
          <button id="btn-save-stage" class="filter-btn btn-dash-save">Save stage</button>
          <span id="stage-save-status" class="save-status"></span>
        </div>
        ${deliverByHint}
      </div>

      <!-- Site URLs -->
      <div style="background:var(--navy-card);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem">
        <div class="section-label" style="margin:0 0 .75rem">Site URLs</div>
        ${fieldRow('preview_url', 'Preview URL',  c.preview_url)}
        ${fieldRow('live_url',    'Live URL',     c.live_url)}
        ${fieldRow('current_url', 'Current URL',  c.current_url)}
        ${fieldRow('domain',      'Domain',       c.domain)}
        <div style="margin-top:.65rem;display:flex;gap:.5rem;align-items:center">
          <button id="btn-save-urls" class="filter-btn btn-dash-save">Save URLs</button>
          <span id="urls-save-status" class="save-status"></span>
        </div>
      </div>

      <!-- Plan & notes -->
      <div style="background:var(--navy-card);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem">
        <div class="section-label" style="margin:0 0 .75rem">Plan &amp; Notes</div>
        <div style="margin-bottom:.5rem">
          <label style="display:block;color:var(--muted);font-size:.78rem;margin-bottom:.2rem">Care plan</label>
          <select id="field-plan"
                  style="width:100%;padding:.38rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--navy);color:var(--white);font-size:.83rem;outline:none">
            <option value=""${!c.plan ? ' selected' : ''}>Undecided</option>
            <option value="care"${c.plan === 'care' ? ' selected' : ''}>Care (£9.99/mo)</option>
            <option value="self_managed"${c.plan === 'self_managed' ? ' selected' : ''}>Self-managed</option>
          </select>
        </div>
        <div style="margin-bottom:.5rem">
          <label style="display:block;color:var(--muted);font-size:.78rem;margin-bottom:.2rem">Notes (operator only)</label>
          <textarea id="field-notes" rows="4"
                    style="width:100%;padding:.38rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--navy);color:var(--white);font-size:.83rem;outline:none;resize:vertical">${escHtml(c.notes || '')}</textarea>
        </div>
        <div style="display:flex;gap:.5rem;align-items:center">
          <button id="btn-save-plan" class="filter-btn btn-dash-save">Save</button>
          <span id="plan-save-status" class="save-status"></span>
        </div>
      </div>

    </div>

    <!-- Send template -->
    <div style="background:var(--navy-card);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem;margin-bottom:1.5rem">
      <div class="section-label" style="margin:0 0 .75rem">Send Email</div>

      <!-- Template selector row -->
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:center;margin-bottom:.5rem">
        <select id="template-select"
                style="padding:.43rem .7rem;border:1px solid var(--border);border-radius:7px;background:var(--navy);color:var(--white);font-size:.875rem;outline:none;flex:1;min-width:200px">
          <option value="">— Select template to preview —</option>
          ${templateOpts}
        </select>
        <input type="date" id="deliver-by-override"
               value="${escAttr(c.next_action_by ? c.next_action_by.substring(0, 10) : '')}"
               title="deliver_by — defaults to Next action by"
               style="padding:.43rem .65rem;border:1px solid var(--border);border-radius:7px;background:var(--navy);color:var(--white);font-size:.875rem;outline:none">
      </div>

      <!-- Advanced toggle -->
      <div style="margin-bottom:.5rem">
        <button id="btn-adv-toggle" type="button"
                style="background:none;border:none;color:var(--muted);font-size:.78rem;cursor:pointer;padding:0">
          ▸ Advanced (extra vars)
        </button>
        <div id="adv-panel" style="display:none;margin-top:.4rem">
          <label style="display:block;color:var(--muted);font-size:.78rem;margin-bottom:.2rem">
            <code style="font-size:.75rem">key=value</code> per line, e.g. <code style="font-size:.75rem">revisions_count=2</code>
          </label>
          <textarea id="extra-vars-input" rows="3"
                    style="width:100%;padding:.38rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--navy);color:var(--white);font-size:.82rem;outline:none;resize:vertical;font-family:monospace"></textarea>
        </div>
      </div>

      <!-- Preview pane — shown once a template is selected -->
      <div id="email-preview-pane" style="display:none;margin-top:.75rem;border-top:1px solid var(--border);padding-top:.75rem">

        <div id="preview-loading" style="display:none;color:var(--muted);font-size:.85rem;padding:.5rem 0">Rendering preview…</div>
        <div id="preview-error"   style="display:none;color:#f87171;font-size:.85rem;padding:.5rem 0"></div>

        <div id="preview-content" style="display:none">
          <!-- Subject -->
          <div style="margin-bottom:.6rem">
            <label style="display:block;color:var(--muted);font-size:.72rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.25rem">Subject</label>
            <input id="preview-subject" type="text"
                   style="width:100%;padding:.4rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--navy);color:var(--white);font-size:.875rem;outline:none">
          </div>
          <!-- Body -->
          <div style="margin-bottom:.85rem">
            <label style="display:block;color:var(--muted);font-size:.72rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.25rem">Body</label>
            <textarea id="preview-body" rows="14"
                      style="width:100%;padding:.5rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--navy);color:var(--white);font-size:.82rem;line-height:1.6;outline:none;resize:vertical;font-family:monospace;white-space:pre"></textarea>
          </div>
          <!-- Send row -->
          <div style="display:flex;align-items:center;gap:.6rem">
            <button id="btn-send-template"
                    style="padding:.5rem 1.3rem;background:var(--amber);color:var(--navy);border:none;border-radius:7px;font-size:.875rem;font-weight:700;cursor:pointer">
              Send →
            </button>
            <button id="btn-preview-refresh" type="button"
                    style="padding:.5rem .9rem;background:none;border:1px solid var(--border);border-radius:7px;font-size:.8rem;color:var(--muted);cursor:pointer">
              Re-render
            </button>
            <span id="send-status" class="save-status"></span>
          </div>
        </div>

      </div>
    </div>

    <!-- Email history -->
    <div style="background:var(--navy-card);border:1px solid var(--border);border-radius:10px;padding:1.25rem 1.5rem;margin-bottom:1.5rem">
      <div class="section-label" style="margin:0 0 .75rem">Email history</div>
      <ul style="list-style:none">${emailRows}</ul>
    </div>
  `;

  // ── Wire iframe toggle ──
  // Do not use src="" — browsers resolve that to the dashboard URL, so the portal never loads.
  document.getElementById('toggle-portal-iframe').addEventListener('click', function () {
    const wrap   = document.getElementById('portal-iframe-wrap');
    const iframe = document.getElementById('portal-iframe');
    const hidden = wrap.style.display === 'none';
    wrap.style.display = hidden ? '' : 'none';
    this.textContent   = hidden ? 'Hide portal preview ↑' : 'Show portal preview ↓';
    if (hidden) {
      const target = iframe.dataset.portalSrc || portalUrl;
      if (iframe.getAttribute('src') !== target) iframe.setAttribute('src', target);
    }
  });

  // ── Wire email log delete buttons ──
  document.querySelectorAll('.btn-delete-email').forEach(btn => {
    btn.addEventListener('click', async function () {
      const id   = this.dataset.logId;
      const slug = this.dataset.logSlug;
      if (!id || !slug) return;
      const subject = this.closest('li')?.querySelector('span:nth-child(2)')?.textContent || 'this email';
      if (!confirm(`Delete "${subject.trim()}" from the email history?\n\nThis removes it from both the dashboard and the client's portal view. The email itself has already been sent — this only removes the record.`)) return;
      this.disabled = true;
      try {
        await apiPost({ action: 'email_log_delete', id: Number(id), slug });
        this.closest('li').remove();
      } catch (err) {
        alert('Delete failed: ' + err.message);
        this.disabled = false;
      }
    });
  });

  // ── Stage date UI: acknowledged → since-date; other stages → deliver-by picker ──
  const stageSelectEl = document.getElementById('stage-select');
  syncStageDateUi(c.stage);
  stageSelectEl?.addEventListener('change', () => syncStageDateUi(stageSelectEl.value));

  // ── Wire stage save ──
  document.getElementById('btn-save-stage').addEventListener('click', async function () {
    const stage  = stageSelectEl.value;
    const status = document.getElementById('stage-save-status');
    const body   = { action: 'client_set_stage', slug: c.slug, stage };

    // Only send deliver-by when not acknowledged — avoids wiping the portal date with an empty input.
    if (stage !== 'acknowledged') {
      const dateVal = document.getElementById('next-action-input')?.value;
      if (dateVal) body.next_action_by = dateVal;
    }

    this.disabled = true; status.textContent = 'Saving…'; status.className = 'save-status';
    try {
      await apiPost(body);
      status.textContent = 'Saved ✓'; status.className = 'save-status ok';
      setTimeout(() => loadClientDetail(c.slug), 600);
    } catch (err) {
      status.textContent = 'Error: ' + err.message; status.className = 'save-status err';
    } finally { this.disabled = false; }
  });

  // ── Wire URLs save ──
  document.getElementById('btn-save-urls').addEventListener('click', async function () {
    const fields = {};
    ['preview_url', 'live_url', 'current_url', 'domain'].forEach(f => {
      fields[f] = document.getElementById(`field-${f}`)?.value.trim() || null;
    });
    const status = document.getElementById('urls-save-status');
    this.disabled = true; status.textContent = 'Saving…'; status.className = 'save-status';
    try {
      await apiPost({ action: 'client_set_fields', slug: c.slug, fields });
      status.textContent = 'Saved ✓'; status.className = 'save-status ok';
      setTimeout(() => { status.textContent = ''; }, 2500);
    } catch (err) {
      status.textContent = 'Error: ' + err.message; status.className = 'save-status err';
    } finally { this.disabled = false; }
  });

  // ── Wire plan + notes save ──
  document.getElementById('btn-save-plan').addEventListener('click', async function () {
    const fields = {
      plan:  document.getElementById('field-plan')?.value  || null,
      notes: document.getElementById('field-notes')?.value || null,
    };
    const status = document.getElementById('plan-save-status');
    this.disabled = true; status.textContent = 'Saving…'; status.className = 'save-status';
    try {
      await apiPost({ action: 'client_set_fields', slug: c.slug, fields });
      status.textContent = 'Saved ✓'; status.className = 'save-status ok';
      setTimeout(() => { status.textContent = ''; }, 2500);
    } catch (err) {
      status.textContent = 'Error: ' + err.message; status.className = 'save-status err';
    } finally { this.disabled = false; }
  });

  // ── Advanced toggle ──
  document.getElementById('btn-adv-toggle').addEventListener('click', function () {
    const panel = document.getElementById('adv-panel');
    const open  = panel.style.display !== 'none';
    panel.style.display  = open ? 'none' : 'block';
    this.textContent     = open ? '▸ Advanced (extra vars)' : '▾ Advanced (extra vars)';
  });

  // ── Preview helpers ──
  function parseExtraVars() {
    const raw = document.getElementById('extra-vars-input')?.value || '';
    const out = {};
    raw.split('\n').forEach(line => {
      const eq = line.indexOf('=');
      if (eq > 0) {
        const k = line.slice(0, eq).trim();
        const v = line.slice(eq + 1).trim();
        if (k) out[k] = v;
      }
    });
    return out;
  }

  async function renderPreview() {
    const templateId = document.getElementById('template-select').value;
    const pane    = document.getElementById('email-preview-pane');
    const loading = document.getElementById('preview-loading');
    const errEl   = document.getElementById('preview-error');
    const content = document.getElementById('preview-content');

    if (!templateId) {
      pane.style.display = 'none';
      return;
    }

    pane.style.display    = 'block';
    loading.style.display = 'block';
    errEl.style.display   = 'none';
    content.style.display = 'none';

    const extra_vars = parseExtraVars();
    const deliverBy  = document.getElementById('deliver-by-override').value;
    if (deliverBy) extra_vars.deliver_by = deliverBy;

    try {
      const result = await apiPost({ action: 'client_preview', slug: c.slug, templateId, extra_vars });
      loading.style.display = 'none';
      if (!result.ok) {
        errEl.textContent   = 'Preview error: ' + (result.error || 'unknown');
        errEl.style.display = 'block';
        return;
      }
      document.getElementById('preview-subject').value = result.subject || '';
      document.getElementById('preview-body').value    = result.body    || '';
      content.style.display = 'block';
    } catch (err) {
      loading.style.display = 'none';
      errEl.textContent     = 'Preview error: ' + err.message;
      errEl.style.display   = 'block';
    }
  }

  // Trigger preview when template or date changes
  document.getElementById('template-select').addEventListener('change', renderPreview);
  document.getElementById('deliver-by-override').addEventListener('change', renderPreview);
  document.getElementById('extra-vars-input').addEventListener('blur', () => {
    if (document.getElementById('template-select').value) renderPreview();
  });
  document.getElementById('btn-preview-refresh').addEventListener('click', renderPreview);

  // ── Wire send template ──
  document.getElementById('btn-send-template').addEventListener('click', async function () {
    const templateId = document.getElementById('template-select').value;
    if (!templateId) { alert('Please select a template first.'); return; }

    if (STUB_TEMPLATE_IDS.has(templateId)) {
      alert(`"${templateId}" hasn't been written yet — it will send a placeholder stub to the client. Either implement it in templates.js first, or choose a different template.`);
      return;
    }

    const subject = document.getElementById('preview-subject')?.value.trim();
    const body    = document.getElementById('preview-body')?.value.trim();
    if (!subject || !body) { alert('Preview hasn\'t loaded yet — wait a moment and try again.'); return; }

    const templateLabel = CLIENT_TEMPLATE_LABELS[templateId] || templateId;
    if (!confirm(`Send "${templateLabel}" to ${c.email}?\n\nThis will send the email exactly as shown in the preview.`)) return;

    const status = document.getElementById('send-status');
    this.disabled = true; status.textContent = 'Sending…'; status.className = 'save-status';
    try {
      const result = await apiPost({ action: 'client_send', slug: c.slug, templateId, subject, body });
      if (result.ok) {
        status.textContent = 'Sent ✓'; status.className = 'save-status ok';
        setTimeout(() => loadClientDetail(c.slug), 1200);
      } else {
        status.textContent = 'Send failed: ' + (result.error || 'unknown'); status.className = 'save-status err';
      }
    } catch (err) {
      status.textContent = 'Error: ' + err.message; status.className = 'save-status err';
    } finally { this.disabled = false; }
  });
}
</script>
</body>
</html>
