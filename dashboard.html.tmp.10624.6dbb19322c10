<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — NeoBookworm</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:        #0f1f3d;
    --navy-light:  #162847;
    --navy-card:   #1a3060;
    --amber:       #f5a623;
    --amber-dim:   #c4841a;
    --white:       #ffffff;
    --muted:       #8aa0c0;
    --border:      #243d6a;
    --green:       #34c97e;
    --blue:        #4b9cf5;
    --orange:      #f5813a;
    --red:         #e05050;
    --grey:        #607090;
    --purple:      #9b7fe8;
  }

  body {
    background: var(--navy);
    color: var(--white);
    font-family: 'DM Sans', system-ui, sans-serif;
    min-height: 100vh;
  }

  /* ── Login overlay ─────────────────────────────────────────────────────── */

  #login-overlay {
    position: fixed; inset: 0;
    background: var(--navy);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
  }

  .login-box {
    background: var(--navy-light);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    width: min(400px, 92vw);
    text-align: center;
  }

  .login-box h1 { font-size: 1.4rem; font-weight: 700; margin-bottom: .35rem; }
  .login-box p  { color: var(--muted); font-size: .9rem; margin-bottom: 1.5rem; }

  .login-box input {
    width: 100%; padding: .75rem 1rem;
    border: 1px solid var(--border); border-radius: 8px;
    background: var(--navy); color: var(--white);
    font-size: 1rem; margin-bottom: 1rem; outline: none;
  }
  .login-box input:focus { border-color: var(--amber); }

  .login-box button {
    width: 100%; padding: .75rem;
    background: var(--amber); color: var(--navy);
    border: none; border-radius: 8px;
    font-size: 1rem; font-weight: 700; cursor: pointer;
  }
  .login-box button:hover { background: var(--amber-dim); }

  #login-error { color: var(--red); font-size: .85rem; margin-top: .75rem; min-height: 1.2em; }

  /* ── App shell ─────────────────────────────────────────────────────────── */

  #app { display: none; }

  header {
    background: var(--navy-light);
    border-bottom: 1px solid var(--border);
    padding: .75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .logo {
    font-size: 1.1rem; font-weight: 700;
    color: var(--amber); text-decoration: none;
    letter-spacing: -.01em;
  }

  /* ── Tab navigation ────────────────────────────────────────────────────── */

  .tab-nav {
    display: flex;
    gap: .25rem;
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: .2rem;
  }

  .tab-btn {
    padding: .35rem .9rem;
    border: none; border-radius: 6px;
    background: none; color: var(--muted);
    font-size: .85rem; font-weight: 600;
    cursor: pointer; transition: background .15s, color .15s;
    white-space: nowrap;
  }
  .tab-btn:hover { color: var(--white); }
  .tab-btn.active { background: var(--navy-card); color: var(--white); }

  .tab-badge {
    display: inline-block;
    background: var(--red);
    color: #fff;
    font-size: .65rem;
    font-weight: 700;
    border-radius: 10px;
    padding: .05rem .4rem;
    margin-left: .3rem;
    vertical-align: middle;
    line-height: 1.5;
  }

  .breadcrumb {
    color: var(--muted); font-size: .85rem;
    display: flex; align-items: center; gap: .4rem;
    flex: 1;
  }
  .breadcrumb .sep   { opacity: .4; }
  .breadcrumb .active { color: var(--white); }

  #btn-back {
    display: none;
    background: none; border: 1px solid var(--border);
    color: var(--muted); padding: .4rem .9rem;
    border-radius: 6px; font-size: .85rem; cursor: pointer;
  }
  #btn-back:hover { color: var(--white); border-color: var(--muted); }

  main { padding: 2rem 1.5rem; max-width: 1100px; margin: 0 auto; }

  /* ── Loading / error ───────────────────────────────────────────────────── */

  .state-msg { text-align: center; padding: 4rem 1rem; color: var(--muted); }

  /* ── Summary view ──────────────────────────────────────────────────────── */

  .summary-header {
    display: flex; align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem; flex-wrap: wrap; gap: .5rem;
  }
  .summary-header h2 { font-size: 1.4rem; font-weight: 700; }

  .total-badge {
    background: var(--navy-card); border: 1px solid var(--border);
    border-radius: 20px; padding: .25rem .85rem;
    font-size: .85rem; color: var(--muted);
  }
  .total-badge strong { color: var(--white); }

  .section-label {
    font-size: .7rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--muted); margin: 1.75rem 0 .75rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: .75rem;
  }

  .card {
    background: var(--navy-card); border: 1px solid var(--border);
    border-radius: 10px; padding: 1.1rem 1.25rem;
    cursor: pointer; transition: border-color .15s, transform .1s;
    position: relative; overflow: hidden;
  }
  .card::before {
    content: ''; position: absolute;
    left: 0; top: 0; bottom: 0; width: 4px;
    border-radius: 10px 0 0 10px;
    background: var(--card-color, var(--grey));
  }
  .card:hover { border-color: var(--card-color, var(--muted)); transform: translateY(-1px); }
  .card-count { font-size: 2rem; font-weight: 700; line-height: 1; color: var(--card-color, var(--white)); margin-bottom: .4rem; }
  .card-label { font-size: .82rem; color: var(--muted); line-height: 1.35; }

  /* ── List view ─────────────────────────────────────────────────────────── */

  .list-header {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem; flex-wrap: wrap; gap: .75rem;
  }
  .list-header h2 { font-size: 1.25rem; font-weight: 700; }
  .list-header h2 .count-tag { font-size: .75rem; font-weight: 400; color: var(--muted); margin-left: .5rem; }

  .list-controls { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; }

  #submissions-search-input {
    padding: .5rem .9rem; border: 1px solid var(--border);
    border-radius: 8px; background: var(--navy-card);
    color: var(--white); font-size: .9rem;
    width: min(220px, 100%); outline: none;
  }
  #submissions-search-input:focus { border-color: var(--amber); }

  .submissions-overview { margin-bottom: 1.25rem; }
  .submissions-overview .section-label { margin-top: 0; }

  .src-pill {
    display: inline-block;
    font-size: .68rem; font-weight: 700;
    letter-spacing: .04em; text-transform: uppercase;
    border-radius: 4px; padding: .15rem .45rem;
    white-space: nowrap;
  }
  .src-enquiry { background: rgba(75, 156, 245, .2); color: var(--blue); }
  .src-intake  { background: rgba(245, 166, 35, .2); color: var(--amber); }
  .src-contact { background: rgba(46, 196, 182, .2); color: #2ec4b6; }

  .filter-btn.source-active { border-color: var(--amber); color: var(--white); }

  .filter-btns { display: flex; gap: .25rem; }

  .filter-btn {
    padding: .4rem .8rem; border: 1px solid var(--border);
    border-radius: 6px; background: none;
    color: var(--muted); font-size: .8rem; cursor: pointer;
  }
  .filter-btn:hover { color: var(--white); }
  .filter-btn.active { background: var(--navy-card); color: var(--white); border-color: var(--muted); }

  /* Primary save actions in client detail (match Save stage) */
  .btn-dash-save {
    border-color: var(--amber) !important;
    color: var(--amber) !important;
  }
  .btn-dash-save:hover { color: var(--white) !important; border-color: var(--amber) !important; }

  .table-wrap { overflow-x: auto; }

  table { width: 100%; border-collapse: collapse; font-size: .875rem; }

  thead th {
    text-align: left; padding: .6rem .9rem;
    color: var(--muted); font-weight: 600;
    font-size: .75rem; letter-spacing: .04em;
    text-transform: uppercase; border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  tbody tr { border-bottom: 1px solid var(--border); cursor: pointer; transition: background .1s; }
  tbody tr:hover { background: var(--navy-card); }
  tbody td { padding: .7rem .9rem; vertical-align: middle; color: var(--white); }
  tbody td.muted { color: var(--muted); }

  /* ── Prospect column filters ───────────────────────────────────────────── */
  .filter-row th {
    padding: .25rem .45rem .5rem;
    vertical-align: top;
    background: var(--navy-light);
    border-bottom: 2px solid var(--border);
  }
  .col-filter {
    width: 100%; padding: .28rem .45rem;
    border: 1px solid var(--border); border-radius: 5px;
    background: var(--navy); color: var(--white);
    font-size: .78rem; font-family: inherit; outline: none;
  }
  .col-filter:focus { border-color: var(--amber); }
  .col-filter option { background: var(--navy-card); }
  .rating-filter-wrap { display: flex; gap: 3px; }
  .rating-filter-wrap .col-filter { min-width: 0; }
  .table-wrap.is-loading tbody { opacity: .45; pointer-events: none; }
  .filter-active-bar {
    display: flex; align-items: center; gap: .5rem; flex-wrap: wrap;
    margin-bottom: .75rem; font-size: .83rem; color: var(--muted);
  }
  .btn-clear-filters, .btn-clear-sorts {
    background: none; border: 1px solid var(--border); border-radius: 5px;
    color: var(--amber); font-size: .78rem; padding: .2rem .6rem; cursor: pointer;
  }
  .btn-clear-filters:hover, .btn-clear-sorts:hover { background: var(--navy-card); }
  .filter-active-bar .sep { opacity: .4; }

  /* ── Prospect column sorting ───────────────────────────────────────────── */
  .sortable-th {
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
  }
  .sortable-th:hover { color: var(--white); }
  .sortable-th:not(.is-sorted)::after {
    content: ' ⇅';
    font-size: .65rem;
    opacity: .22;
  }
  .sort-indicator {
    display: inline-flex; align-items: center; gap: 2px;
    margin-left: .3rem; color: var(--amber);
    font-size: .82rem; vertical-align: middle;
  }
  .sort-badge {
    display: inline-block;
    background: var(--amber); color: var(--navy);
    border-radius: 3px; padding: 0 .22rem;
    line-height: 1.5; font-size: .6rem; font-weight: 800;
    vertical-align: middle;
  }

  .pill {
    display: inline-block; padding: .15rem .55rem;
    border-radius: 20px; font-size: .72rem; font-weight: 600;
    background: var(--navy); border: 1px solid var(--border); color: var(--muted);
  }
  .pill.has-website   { color: var(--green);  border-color: var(--green); }
  .pill.no-website    { color: var(--grey);   border-color: var(--grey); }
  .pill.ok            { color: var(--green);  border-color: var(--green); }
  .pill.fail          { color: var(--red);    border-color: var(--red); }
  .pill.pending-pill  { color: var(--orange); border-color: var(--orange); }
  .pill.handled       { color: var(--green);  border-color: var(--green); }
  .pill.unhandled     { color: var(--amber);  border-color: var(--amber); }

  .pagination {
    display: flex; align-items: center; justify-content: center;
    gap: .75rem; margin-top: 1.5rem; font-size: .875rem; color: var(--muted);
  }
  .pagination button {
    background: var(--navy-card); border: 1px solid var(--border);
    color: var(--white); padding: .4rem .9rem;
    border-radius: 6px; cursor: pointer; font-size: .85rem;
  }
  .pagination button:disabled { opacity: .35; cursor: default; }
  .pagination button:not(:disabled):hover { border-color: var(--amber); color: var(--amber); }

  /* ── Record detail modal ───────────────────────────────────────────────── */

  #modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.65); z-index: 50;
    align-items: flex-start; justify-content: center;
    padding: 2rem 1rem; overflow-y: auto;
  }
  #modal-overlay.open { display: flex; }

  .modal {
    background: var(--navy-light); border: 1px solid var(--border);
    border-radius: 14px; width: min(740px, 100%);
    padding: 2rem; position: relative;
  }
  .modal-close {
    position: absolute; top: 1rem; right: 1rem;
    background: none; border: none; color: var(--muted);
    font-size: 1.4rem; cursor: pointer; line-height: 1;
  }
  .modal-close:hover { color: var(--white); }
  .modal h2 { font-size: 1.3rem; margin-bottom: .3rem; padding-right: 2rem; }
  .modal .modal-status { font-size: .8rem; color: var(--muted); margin-bottom: .75rem; }

  .modal-actions {
    display: flex; align-items: center; gap: .6rem; flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .btn-edit {
    padding: .5rem 1.1rem; background: transparent; color: var(--amber);
    border: 1px solid var(--amber); border-radius: 7px; font-size: .85rem;
    font-weight: 600; cursor: pointer; transition: background .15s, color .15s;
  }
  .btn-edit:hover { background: var(--amber); color: var(--navy); }
  .btn-cancel-edit {
    padding: .5rem 1.1rem; background: transparent; color: var(--muted);
    border: 1px solid var(--border); border-radius: 7px; font-size: .85rem;
    font-weight: 600; cursor: pointer;
  }
  .btn-cancel-edit:hover { color: var(--white); border-color: var(--muted); }

  .record-edit-grid input[type="text"],
  .record-edit-grid input[type="email"],
  .record-edit-grid input[type="url"],
  .record-edit-grid input[type="number"],
  .record-edit-grid select,
  .record-edit-grid textarea {
    width: 100%; padding: .55rem .8rem;
    border: 1px solid var(--border); border-radius: 7px;
    background: var(--navy-light); color: var(--white);
    font-size: .9rem; font-family: inherit; outline: none;
    transition: border-color .15s;
  }
  .record-edit-grid input:focus,
  .record-edit-grid select:focus,
  .record-edit-grid textarea:focus { border-color: var(--amber); }
  .record-edit-grid textarea { resize: vertical; min-height: 80px; }
  .record-edit-grid select option { background: var(--navy-light); }

  .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .9rem 1.5rem; }
  @media (max-width: 500px) { .field-grid { grid-template-columns: 1fr; } }

  .field-group { display: flex; flex-direction: column; gap: .2rem; }
  .field-label {
    font-size: .7rem; text-transform: uppercase;
    letter-spacing: .07em; color: var(--muted); font-weight: 600;
  }
  .field-value { font-size: .9rem; color: var(--white); word-break: break-word; }
  .field-value a { color: var(--amber); text-decoration: none; }
  .field-value a:hover { text-decoration: underline; }
  .field-value.empty { color: var(--grey); font-style: italic; }

  .section-divider { border: none; border-top: 1px solid var(--border); margin: 1.25rem 0; }

  /* ── Edit section ──────────────────────────────────────────────────────── */

  .edit-section {
    background: var(--navy); border: 1px solid var(--border);
    border-radius: 10px; padding: 1.25rem; margin-top: 1.5rem;
  }
  .edit-section h3 {
    font-size: .75rem; text-transform: uppercase; letter-spacing: .08em;
    color: var(--muted); font-weight: 600; margin-bottom: 1rem;
  }

  .edit-row { margin-bottom: .9rem; }
  .edit-row label {
    display: block; font-size: .7rem; text-transform: uppercase;
    letter-spacing: .07em; color: var(--muted); font-weight: 600; margin-bottom: .3rem;
  }
  .edit-row select,
  .edit-row input[type="text"],
  .edit-row input[type="number"],
  .edit-row textarea {
    width: 100%; padding: .55rem .8rem;
    border: 1px solid var(--border); border-radius: 7px;
    background: var(--navy-light); color: var(--white);
    font-size: .9rem; font-family: inherit; outline: none;
    transition: border-color .15s;
  }
  .edit-row select:focus,
  .edit-row input:focus,
  .edit-row textarea:focus { border-color: var(--amber); }
  .edit-row textarea { resize: vertical; min-height: 80px; }
  .edit-row select option { background: var(--navy-light); }

  .edit-row input[type="checkbox"] {
    width: 1.1rem; height: 1.1rem; cursor: pointer;
    accent-color: var(--amber);
  }

  .checkbox-row {
    display: flex; align-items: center; gap: .6rem;
  }
  .checkbox-row label {
    display: inline; font-size: .9rem; text-transform: none;
    letter-spacing: 0; color: var(--white); font-weight: 400;
    margin: 0; cursor: pointer;
  }

  .field-group.disqualify-row { display: none; }
  .field-group.disqualify-row.visible { display: flex; }

  .edit-actions { display: flex; align-items: center; gap: .75rem; margin-top: 1rem; }

  .promote-section {
    margin: 1.25rem 0;
    padding: 1rem 1.15rem;
    background: rgba(245, 166, 35, .08);
    border: 1px solid rgba(245, 166, 35, .35);
    border-radius: 10px;
  }
  .promote-section h3 {
    margin: 0 0 .5rem;
    font-size: .95rem;
    color: var(--amber);
    font-weight: 700;
  }
  .promote-section p { margin: 0 0 .75rem; font-size: .88rem; color: var(--muted); line-height: 1.45; }
  .promote-section.promote-linked {
    background: rgba(34, 197, 94, .08);
    border-color: rgba(34, 197, 94, .35);
  }
  .promote-section.promote-linked h3 { color: var(--green); }
  .promote-actions { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
  .promote-journey-row { margin-bottom: .75rem; }
  .promote-journey-row label {
    display: block; font-size: .78rem; color: var(--muted);
    text-transform: uppercase; letter-spacing: .04em; margin-bottom: .35rem;
  }
  .promote-journey-row select {
    width: 100%; max-width: 420px;
    padding: .45rem .65rem; border: 1px solid var(--border); border-radius: 7px;
    background: var(--navy); color: var(--white); font-size: .88rem;
  }
  .btn-promote {
    padding: .55rem 1.2rem; background: var(--amber); color: var(--navy);
    border: none; border-radius: 7px; font-size: .88rem; font-weight: 700; cursor: pointer;
  }
  .btn-promote:disabled { opacity: .45; cursor: default; }
  .btn-promote:not(:disabled):hover { background: var(--amber-dim); }
  .btn-promote-secondary {
    padding: .5rem 1rem; background: var(--navy-card); color: var(--amber);
    border: 1px solid var(--amber); border-radius: 7px; font-size: .85rem;
    font-weight: 600; cursor: pointer; text-decoration: none;
  }
  .btn-promote-secondary:hover { background: rgba(245, 166, 35, .12); }
  .promote-status { font-size: .85rem; margin-left: .5rem; min-height: 1.2em; }
  .promote-status.ok  { color: var(--green); }
  .promote-status.err { color: var(--red); }

  .btn-save {
    padding: .6rem 1.4rem; background: var(--amber); color: var(--navy);
    border: none; border-radius: 7px; font-size: .9rem; font-weight: 700;
    cursor: pointer; transition: background .15s, opacity .15s;
  }
  .btn-save:disabled { opacity: .4; cursor: default; }
  .btn-save:not(:disabled):hover { background: var(--amber-dim); }

  .save-status { font-size: .85rem; min-height: 1.2em; }
  .save-status.ok  { color: var(--green); }
  .save-status.err { color: var(--red); }

  .btn-delete {
    padding: .6rem 1.4rem; background: none; color: var(--red);
    border: 1px solid var(--red); border-radius: 7px;
    font-size: .9rem; font-weight: 600; cursor: pointer;
    transition: background .15s, color .15s;
    margin-left: auto;
  }
  .btn-delete:hover { background: var(--red); color: var(--white); }
  .btn-delete:disabled { opacity: .4; cursor: default; }

  .delete-confirm {
    display: flex; align-items: center; gap: .6rem; margin-left: auto;
  }
  .delete-confirm span { font-size: .85rem; color: var(--muted); }
  .btn-confirm-yes {
    padding: .5rem 1rem; background: var(--red); color: var(--white);
    border: none; border-radius: 6px; font-size: .85rem; font-weight: 700; cursor: pointer;
  }
  .btn-confirm-yes:hover { opacity: .85; }
  .btn-confirm-no {
    padding: .5rem 1rem; background: none; color: var(--muted);
    border: 1px solid var(--border); border-radius: 6px; font-size: .85rem; cursor: pointer;
  }
  .btn-confirm-no:hover { color: var(--white); border-color: var(--muted); }

  .text-multiline {
    white-space: pre-wrap;
    word-break: break-word;
    font-family: inherit;
  }

  /* ── Campaign status badges ────────────────────────────────────────────── */
  .camp-badge {
    display: inline-block; padding: .15rem .55rem;
    border-radius: 20px; font-size: .72rem; font-weight: 600;
    border: 1px solid; background: none;
  }
  .camp-badge.draft    { color: #888;    border-color: #888; }
  .camp-badge.active   { color: #22c55e; border-color: #22c55e; }
  .camp-badge.paused   { color: #f5a623; border-color: #f5a623; }
  .camp-badge.complete { color: #3b82f6; border-color: #3b82f6; }
  tbody tr.camp-row-complete { opacity: .78; }
  tbody tr.camp-row-complete:hover { opacity: 1; }

  .camp-id-cell {
    font-family: 'Courier New', monospace;
    font-size: .75rem; color: var(--muted);
    cursor: pointer; user-select: none;
    border-bottom: 1px dashed var(--border);
    white-space: nowrap;
    min-width: 35ch;
    display: inline-block;
  }
  .camp-id-cell:hover { color: var(--amber); border-color: var(--amber); }

  /* ── Progress bar ────────────────────────────────────────────────────── */
  .prog-wrap {
    display: inline-block; width: 80px; height: 5px;
    background: var(--border); border-radius: 3px;
    vertical-align: middle; margin-left: .35rem; overflow: hidden;
  }
  .prog-fill { height: 100%; border-radius: 3px; background: var(--green); }

  /* ── Priority ────────────────────────────────────────────────────────── */
  .priority-cell { display: flex; align-items: center; gap: .25rem; }
  .priority-val  { font-weight: 700; min-width: 2.2em; text-align: center; font-size: .85rem; }
  .btn-boost {
    background: var(--navy); border: 1px solid var(--border);
    color: var(--muted); border-radius: 4px;
    padding: .1rem .3rem; font-size: .65rem; cursor: pointer; line-height: 1.4;
    transition: color .15s, border-color .15s;
  }
  .btn-boost:hover { color: var(--amber); border-color: var(--amber); }

  /* ── Campaign action buttons ─────────────────────────────────────────── */
  .btn-camp-action {
    padding: .3rem .7rem; border-radius: 6px;
    font-size: .78rem; font-weight: 600; cursor: pointer;
    border: 1px solid; background: none; white-space: nowrap;
  }
  .btn-camp-action:disabled { opacity: .45; cursor: default; }
  .btn-camp-action.activate { color: #22c55e; border-color: #22c55e; }
  .btn-camp-action.activate:not(:disabled):hover { background: rgba(34,197,94,.12); }
  .btn-camp-action.pause    { color: var(--amber); border-color: var(--amber); }
  .btn-camp-action.pause:not(:disabled):hover    { background: rgba(245,166,35,.12); }
  .btn-camp-action.resume   { color: #3b82f6; border-color: #3b82f6; }
  .btn-camp-action.resume:not(:disabled):hover   { background: rgba(59,130,246,.12); }

  /* ── Spinner ─────────────────────────────────────────────────────────── */
  @keyframes spin { to { transform: rotate(360deg); } }
  .spinner {
    display: inline-block; width: .85em; height: .85em;
    border: 2px solid currentColor; border-top-color: transparent;
    border-radius: 50%; animation: spin .55s linear infinite; vertical-align: middle;
  }

  /* ── Outbox section ──────────────────────────────────────────────────── */
  .outbox-summary-bar {
    display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    background: var(--navy); border: 1px solid var(--border);
    border-radius: 8px; padding: .7rem 1rem;
    margin-bottom: .75rem; font-size: .875rem;
  }
  .outbox-summary-bar .summ-lines { display: flex; flex-direction: column; gap: .2rem; flex: 1; min-width: 12rem; }
  .outbox-summary-bar .summ-line2 { color: var(--muted); font-size: .82rem; }
  .outbox-summary-bar .summ-sep  { color: var(--border); }
  .outbox-summary-bar .summ-btns { margin-left: auto; display: flex; gap: .5rem; }

  tr.outbox-prospect-header { background: var(--navy-card); cursor: pointer; }
  tr.outbox-prospect-header.suppressed { border-left: 3px solid var(--purple); }
  tr.outbox-prospect-header td { padding: .65rem .75rem; vertical-align: middle; }
  .outbox-prospect-header-inner {
    display: flex; align-items: center; gap: .65rem; flex-wrap: wrap; width: 100%;
  }
  .outbox-toggle { color: var(--muted); font-size: .7rem; width: 1rem; flex-shrink: 0; user-select: none; }
  .outbox-prospect-name { font-weight: 700; }
  .outbox-prospect-email { color: var(--muted); font-size: .82rem; }
  .outbox-prospect-badge {
    font-size: .72rem; font-weight: 600; padding: .15rem .5rem; border-radius: 4px;
    border: 1px solid; white-space: nowrap;
  }
  .outbox-prospect-actions { margin-left: auto; display: flex; gap: .35rem; flex-wrap: wrap; }
  .btn-ob-seq {
    padding: .22rem .55rem; border-radius: 5px; font-size: .72rem; font-weight: 600;
    cursor: pointer; border: 1px solid; background: none; white-space: nowrap;
  }
  .btn-ob-seq.approve { color: #22c55e; border-color: #22c55e; }
  .btn-ob-seq.approve:not(:disabled):hover { background: rgba(34,197,94,.1); }
  .btn-ob-seq.revoke { color: var(--grey); border-color: var(--border); }
  .btn-ob-seq.revoke:not(:disabled):hover { color: var(--muted); }
  .btn-ob-seq.suppress { color: var(--red); border-color: var(--red); }
  .btn-ob-seq.suppress:not(:disabled):hover { background: rgba(224,80,80,.1); }
  .btn-ob-seq.unsuppress { color: var(--muted); border-color: var(--border); font-weight: 400; font-size: .7rem; }
  .btn-ob-seq.unsuppress:not(:disabled):hover { color: var(--white); }

  tr.outbox-seq-row td { font-size: .85rem; }
  tr.outbox-seq-row td:first-child { border-left: 3px solid var(--border); padding-left: 1.25rem; }
  tr.outbox-seq-row.suppressed td { opacity: .75; }
  .outbox-seq-label { color: var(--muted); font-size: .78rem; white-space: nowrap; }
  .outbox-subject { max-width: 14rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .btn-outbox-hdr {
    padding: .35rem .8rem; border-radius: 6px;
    font-size: .8rem; font-weight: 600; cursor: pointer; border: 1px solid; background: none;
  }
  .btn-outbox-hdr:disabled { opacity: .45; cursor: default; }
  .btn-outbox-hdr.review:not(:disabled):hover      { background: rgba(245,166,35,.12); }
  .btn-outbox-hdr.review      { color: var(--amber); border-color: var(--amber); }
  .btn-outbox-hdr.approve-all { color: #22c55e; border-color: #22c55e; }
  .btn-outbox-hdr.approve-all:not(:disabled):hover { background: rgba(34,197,94,.12); }

  .outbox-cell-actions { display: flex; gap: .35rem; flex-wrap: wrap; }
  .btn-ob {
    padding: .22rem .55rem; border-radius: 5px;
    font-size: .72rem; font-weight: 600; cursor: pointer; border: 1px solid; background: none;
    white-space: nowrap;
  }
  .btn-ob:disabled { opacity: .45; cursor: default; }
  .btn-ob.preview:not(:disabled):hover { color: var(--white); border-color: var(--muted); }
  .btn-ob.preview  { color: var(--muted); border-color: var(--border); }
  .btn-ob.approve  { color: #22c55e; border-color: #22c55e; }
  .btn-ob.approve:not(:disabled):hover  { background: rgba(34,197,94,.1); }
  .btn-ob.revoke   { color: var(--grey); border-color: var(--border); font-weight: 400; font-size: .7rem; }
  .btn-ob.revoke:not(:disabled):hover   { color: var(--muted); border-color: var(--muted); }
  .btn-ob.skip     { color: var(--red); border-color: var(--red); }
  .btn-ob.skip:not(:disabled):hover     { background: rgba(224,80,80,.1); }
  .btn-ob.unskip   { color: var(--muted); border-color: var(--border); }
  .btn-ob.unskip:not(:disabled):hover   { color: var(--white); }

  /* ── Email preview modal ─────────────────────────────────────────────── */
  #email-modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.72); z-index: 60;
    align-items: flex-start; justify-content: center;
    padding: 2rem 1rem; overflow-y: auto;
  }
  #email-modal-overlay.open { display: flex; }

  .email-modal {
    background: var(--navy-light); border: 1px solid var(--border);
    border-radius: 14px; width: min(760px, 100%); overflow: hidden;
  }
  .email-modal-top {
    display: flex; align-items: center; gap: .75rem;
    padding: .9rem 1.25rem; border-bottom: 1px solid var(--border);
  }
  .email-modal-top h2 { font-size: 1rem; font-weight: 700; flex: 1; margin: 0; }
  .email-modal-top .modal-close {
    background: none; border: none; color: var(--muted);
    font-size: 1.4rem; cursor: pointer; line-height: 1;
  }
  .email-modal-top .modal-close:hover { color: var(--white); }

  .email-envelope {
    margin: 1rem; border-radius: 8px; overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
  }
  .email-header-pane {
    background: #eaeaea; padding: .75rem 1rem;
    font-size: .82rem; line-height: 1.6; border-bottom: 1px solid #ccc;
  }
  .email-header-row { display: flex; gap: .5rem; }
  .email-header-label { color: #666; min-width: 4.5em; font-weight: 600; }
  .email-header-value { color: #111; word-break: break-word; flex: 1; }

  .email-body-pane {
    background: #fafafa; padding: 1.25rem 1.1rem;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: .9rem; line-height: 1.7; color: #1a1a1a;
    min-height: 160px; white-space: pre-wrap; word-break: break-word;
  }
  .email-body-pane a { color: #1558b0; }
  .email-body-pane a:hover { text-decoration: underline; }

  textarea.email-body-edit {
    width: 100%; padding: 1.1rem;
    background: #fff; color: #1a1a1a;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: .9rem; line-height: 1.7;
    border: none; outline: none; resize: vertical;
    min-height: 200px; box-sizing: border-box;
  }

  .email-modal-footer {
    display: flex; align-items: center; gap: .6rem; flex-wrap: wrap;
    padding: .9rem 1.25rem; border-top: 1px solid var(--border);
  }
  .email-modal-footer .edit-btns     { display: flex; gap: .4rem; }
  .email-modal-footer .approval-btns { margin-left: auto; display: flex; gap: .5rem; }

  .btn-em-edit {
    padding: .38rem .8rem; border-radius: 6px;
    font-size: .8rem; font-weight: 600; cursor: pointer;
    color: var(--muted); border: 1px solid var(--border); background: none;
  }
  .btn-em-edit:hover { color: var(--white); border-color: var(--muted); }
  .btn-em-edit.editing { color: var(--amber); border-color: var(--amber); }

  .btn-em-approve {
    padding: .42rem 1.1rem; border-radius: 6px;
    font-size: .875rem; font-weight: 700; cursor: pointer;
    background: var(--amber); color: var(--navy); border: none;
  }
  .btn-em-approve:not(:disabled):hover { background: var(--amber-dim); }
  .btn-em-approve:disabled { opacity: .5; cursor: default; }

  .btn-em-approve-next {
    padding: .42rem 1.1rem; border-radius: 6px;
    font-size: .875rem; font-weight: 700; cursor: pointer;
    background: #22c55e; color: #fff; border: none;
  }
  .btn-em-approve-next:not(:disabled):hover { background: #16a34a; }
  .btn-em-approve-next:disabled { opacity: .5; cursor: default; }

  .btn-em-approved {
    padding: .42rem 1.1rem; border-radius: 6px;
    font-size: .875rem; font-weight: 600;
    background: none; color: #22c55e; border: 1px solid #22c55e;
    cursor: default;
  }

  .btn-em-revoke {
    padding: .42rem 1.1rem; border-radius: 6px;
    font-size: .875rem; font-weight: 600; cursor: pointer;
    background: none; color: var(--muted); border: 1px solid var(--border);
  }
  .btn-em-revoke:hover { color: var(--white); border-color: var(--muted); }

  .subject-edit-row { display: flex; gap: .5rem; align-items: center; }
  .subject-edit-row input {
    flex: 1; padding: .35rem .65rem;
    border: 1px solid #bbb; border-radius: 5px; outline: none;
    font-size: .82rem; font-family: inherit; color: #111; background: #fff;
  }
  .subject-edit-row input:focus { border-color: #666; }
  .btn-ed-save {
    padding: .3rem .65rem; border-radius: 5px;
    font-size: .77rem; font-weight: 700; cursor: pointer;
    background: var(--amber); color: var(--navy); border: none;
  }
  .btn-ed-save:hover { background: var(--amber-dim); }
  .btn-ed-cancel {
    padding: .3rem .65rem; border-radius: 5px;
    font-size: .77rem; cursor: pointer;
    background: none; border: 1px solid var(--border); color: var(--muted);
  }
  .btn-ed-cancel:hover { color: var(--white); }

  /* ── Clients tab ────────────────────────────────────────────────────────── */
  tr.stuck-row td { background: rgba(224, 80, 80, .07); }
  tr.stuck-row:hover td { background: rgba(224, 80, 80, .14) !important; }
  .save-status      { font-size: .82rem; color: var(--muted); }
  .save-status.ok   { color: var(--green); }
  .save-status.err  { color: var(--red); }
</style>
</head>
<body>

<!-- ── Login ──────────────────────────────────────────────────────────────── -->
<div id="login-overlay">
  <div class="login-box">
    <h1>Dashboard</h1>
    <p>Enter your access token to continue.</p>
    <input type="password" id="token-input" placeholder="Access token" autocomplete="current-password">
    <button id="btn-login">Sign in</button>
    <div id="login-error"></div>
  </div>
</div>

<!-- ── App ────────────────────────────────────────────────────────────────── -->
<div id="app">
  <header>
    <a class="logo" href="/">NeoBookworm</a>
    <nav class="tab-nav">
      <button class="tab-btn active" data-tab="prospects">Prospects</button>
      <button class="tab-btn" data-tab="enquiries" id="enq-tab-btn">Enquiries</button>
      <button class="tab-btn" data-tab="campaigns">Campaigns</button>
      <button class="tab-btn" data-tab="clients">Clients</button>
    </nav>
    <div class="breadcrumb" id="breadcrumb">
      <span class="active">Overview</span>
    </div>
    <button id="btn-back">← Back</button>
  </header>

  <main id="main-content">
    <div class="state-msg" id="loading-msg">Loading…</div>
  </main>
</div>

<!-- ── Record detail modal ────────────────────────────────────────────────── -->
<div id="modal-overlay" role="dialog" aria-modal="true">
  <div class="modal">
    <button class="modal-close" id="modal-close" aria-label="Close">×</button>
    <div id="modal-body"></div>
  </div>
</div>

<!-- ── Email preview modal ────────────────────────────────────────────────── -->
<div id="email-modal-overlay" role="dialog" aria-modal="true">
  <div class="email-modal">
    <div class="email-modal-top">
      <h2 id="email-modal-title">Email Preview</h2>
      <button class="modal-close" id="email-modal-close" aria-label="Close">×</button>
    </div>
    <div id="email-modal-body"></div>
    <div class="email-modal-footer">
      <div class="edit-btns">
        <button class="btn-em-edit" id="btn-edit-subject">Edit subject</button>
        <button class="btn-em-edit" id="btn-edit-body">Edit body</button>
      </div>
      <div class="approval-btns" id="email-approval-btns"></div>
    </div>
  </div>
</div>

<script>
// ── State ────────────────────────────────────────────────────────────────────
const EMPTY_COL_FILTERS = () => ({
  q_business: '', q_contact: '', q_trade: '', q_town: '',
  q_campaign: '',
  has_website: '', min_rating: '', max_rating: '', emailed_filter: '',
});

const EMPTY_CAMP_COL_FILTERS = () => ({
  q_trade: '', q_status: '', q_campaign_id: '',
  min_priority: '', max_priority: '', progress_filter: '',
});

const EMPTY_CAMP_DETAIL_PROSPECT_FILTERS = () => ({
  q_business: '', q_contact: '', q_town: '', q_status: '', emailed_filter: '',
});

const EMPTY_OUTBOX_COL_FILTERS = () => ({
  q_business: '', q_email: '', q_subject: '',
  approval_filter: '', sent_filter: '',
});

const CAMPAIGN_COLS = [
  { label: 'Trade',        col: 'trade'         },
  { label: 'Status',       col: 'status'        },
  { label: 'Progress',     col: 'count_sent'    },
  { label: 'Priority',     col: 'priority'      },
  { label: 'Replied',      col: 'count_replied' },
  { label: 'Created',      col: 'created_at'    },
  { label: 'Campaign ID',  col: 'id'            },
];

const CAMP_DETAIL_PROSPECT_COLS = [
  { label: 'Business',     col: 'business_name'   },
  { label: 'Contact',      col: 'email_address'   },
  { label: 'Town',         col: 'town'            },
  { label: 'Status',       col: 'status'          },
  { label: 'Last emailed', col: 'last_email_sent' },
  { label: 'Contacts',     col: 'contact_count'   },
];

const OUTBOX_COLS = [
  { label: 'Business', col: 'business_name' },
  { label: 'Email',    col: 'email'         },
  { label: 'Subject',  col: 'subject'       },
  { label: 'Approval', col: 'approved'      },
  { label: 'Status',   col: 'sent'          },
];

/** Wait for a full word before column-filter API refresh (ms). */
const FILTER_DEBOUNCE_MS = 700;

// Column config for the Prospects list — order matches table column order
const PROSPECT_COLS = [
  { label: 'Business',     col: 'business_name'   },
  { label: 'Contact',      col: 'contact_name'    },
  { label: 'Trade',        col: 'trade_category'  },
  { label: 'Town',         col: 'town'            },
  { label: 'Website',      col: 'has_website'     },
  { label: 'Rating',       col: 'rating'          },
  { label: 'Last emailed', col: 'last_email_sent' },
];

const PROSPECT_COLS_IN_CAMPAIGN = [
  { label: 'Business',     col: 'business_name'       },
  { label: 'Contact',      col: 'contact_name'        },
  { label: 'Trade',        col: 'trade_category'      },
  { label: 'Town',         col: 'town'                },
  { label: 'Website',      col: 'has_website'         },
  { label: 'Campaign Id',  col: 'campaign_id'         },
  { label: 'Pri',          col: 'campaign_priority'   },
];

const PROSPECT_COLS_EMAILED = [
  { label: 'Business',     col: 'business_name'   },
  { label: 'Contact',      col: 'contact_name'    },
  { label: 'Trade',        col: 'trade_category'  },
  { label: 'Town',         col: 'town'            },
  { label: 'Website',      col: 'has_website'     },
  { label: 'Campaign Id',  col: 'campaign_id'     },
  { label: 'Last emailed', col: 'last_email_sent' },
];

const PROSPECT_COLS_SALVAGE_WEBSITE = [
  { label: 'Business',          col: 'business_name'    },
  { label: 'Trade',             col: 'trade_category'   },
  { label: 'Town',              col: 'town'             },
  { label: 'Website',           col: 'has_website'      },
  { label: 'Website platform',  col: 'website_platform' },
  { label: 'Website agency',    col: 'website_agency'   },
  { label: 'Website URL',       col: 'website_url'      },
];

const PROSPECT_COLS_DISQUALIFIED = [
  { label: 'Business',     col: 'business_name'   },
  { label: 'Trade',        col: 'trade_category'  },
  { label: 'Town',         col: 'town'            },
  { label: 'Website',      col: 'has_website'     },
  { label: 'CH number',    col: 'ch_number'       },
  { label: 'CH status',    col: 'ch_status'       },
  { label: 'Company type', col: 'company_type'    },
];

function getProspectCols(status) {
  if (status === 'In Campaign') return PROSPECT_COLS_IN_CAMPAIGN;
  if (status === 'Emailed') return PROSPECT_COLS_EMAILED;
  if (status === 'Salvage - Website') return PROSPECT_COLS_SALVAGE_WEBSITE;
  if (status === 'Disqualified') return PROSPECT_COLS_DISQUALIFIED;
  return PROSPECT_COLS;
}

/** Default column sorts when opening a status list (cleared when switching status). */
function defaultProspectSorts(status) {
  if (status === 'In Campaign') return [{ col: 'campaign_priority', dir: 'desc' }];
  if (status === 'Emailed') return [{ col: 'last_email_sent', dir: 'desc' }];
  return [];
}

function prospectFilterCell(col, cf) {
  switch (col) {
    case 'business_name':
      return `<input type="search" class="col-filter" data-col="q_business" placeholder="Filter…" value="${escAttr(cf.q_business)}">`;
    case 'contact_name':
      return `<input type="search" class="col-filter" data-col="q_contact" placeholder="Filter…" value="${escAttr(cf.q_contact)}">`;
    case 'trade_category':
      return `<input type="search" class="col-filter" data-col="q_trade" placeholder="Filter…" value="${escAttr(cf.q_trade)}">`;
    case 'town':
      return `<input type="search" class="col-filter" data-col="q_town" placeholder="Filter…" value="${escAttr(cf.q_town)}">`;
    case 'has_website':
      return `<select class="col-filter" data-col="has_website">
        <option value=""  ${cf.has_website === ''  ? 'selected' : ''}>All</option>
        <option value="1" ${cf.has_website === '1' ? 'selected' : ''}>Yes</option>
        <option value="0" ${cf.has_website === '0' ? 'selected' : ''}>No</option>
      </select>`;
    case 'rating':
      return `<div class="rating-filter-wrap">
        <input type="number" class="col-filter" data-col="min_rating" placeholder="Min" min="0" max="5" step="0.1" value="${escAttr(cf.min_rating)}">
        <input type="number" class="col-filter" data-col="max_rating" placeholder="Max" min="0" max="5" step="0.1" value="${escAttr(cf.max_rating)}">
      </div>`;
    case 'campaign_id':
      return `<input type="search" class="col-filter" data-col="q_campaign" placeholder="Filter…" value="${escAttr(cf.q_campaign)}">`;
    case 'last_email_sent':
      return `<select class="col-filter" data-col="emailed_filter">
        <option value=""        ${cf.emailed_filter === ''        ? 'selected' : ''}>Any</option>
        <option value="emailed" ${cf.emailed_filter === 'emailed' ? 'selected' : ''}>Emailed</option>
        <option value="never"   ${cf.emailed_filter === 'never'   ? 'selected' : ''}>Never</option>
      </select>`;
    case 'website_platform':
    case 'website_agency':
    case 'website_url':
    case 'ch_number':
    case 'ch_status':
    case 'company_type':
      return '';
    default:
      return '';
  }
}

function campaignFilterCell(col, cf) {
  switch (col) {
    case 'trade':
      return `<input type="search" class="col-filter" data-col="q_trade" placeholder="Filter…" value="${escAttr(cf.q_trade)}">`;
    case 'status':
      return `<select class="col-filter" data-col="q_status">
        <option value="" ${cf.q_status === '' ? 'selected' : ''}>All</option>
        <option value="draft" ${cf.q_status === 'draft' ? 'selected' : ''}>draft</option>
        <option value="active" ${cf.q_status === 'active' ? 'selected' : ''}>active</option>
        <option value="paused" ${cf.q_status === 'paused' ? 'selected' : ''}>paused</option>
        <option value="complete" ${cf.q_status === 'complete' ? 'selected' : ''}>complete</option>
      </select>`;
    case 'count_sent':
      return `<select class="col-filter" data-col="progress_filter">
        <option value="" ${cf.progress_filter === '' ? 'selected' : ''}>All</option>
        <option value="not_started" ${cf.progress_filter === 'not_started' ? 'selected' : ''}>Not started</option>
        <option value="in_progress" ${cf.progress_filter === 'in_progress' ? 'selected' : ''}>In progress</option>
        <option value="complete" ${cf.progress_filter === 'complete' ? 'selected' : ''}>All sent</option>
      </select>`;
    case 'priority':
      return `<div class="rating-filter-wrap">
        <input type="number" class="col-filter" data-col="min_priority" placeholder="Min" min="-10" max="10" step="1" value="${escAttr(cf.min_priority)}">
        <input type="number" class="col-filter" data-col="max_priority" placeholder="Max" min="-10" max="10" step="1" value="${escAttr(cf.max_priority)}">
      </div>`;
    case 'count_replied':
      return '';
    case 'created_at':
      return '';
    case 'id':
      return `<input type="search" class="col-filter" data-col="q_campaign_id" placeholder="Filter…" value="${escAttr(cf.q_campaign_id)}">`;
    default:
      return '';
  }
}

function campDetailProspectFilterCell(col, cf) {
