    case 'approved':
      return `<select class="col-filter" data-col="approval_filter">
        <option value="" ${cf.approval_filter === '' ? 'selected' : ''}>All</option>
        <option value="approved" ${cf.approval_filter === 'approved' ? 'selected' : ''}>Approved</option>
        <option value="pending" ${cf.approval_filter === 'pending' ? 'selected' : ''}>Awaiting approval</option>
      </select>`;
    case 'sent':
      return `<select class="col-filter" data-col="sent_filter">
        <option value="" ${cf.sent_filter === '' ? 'selected' : ''}>All</option>
        <option value="sent" ${cf.sent_filter === 'sent' ? 'selected' : ''}>Sent</option>
        <option value="unsent" ${cf.sent_filter === 'unsent' ? 'selected' : ''}>Unsent</option>
        <option value="skipped" ${cf.sent_filter === 'skipped' ? 'selected' : ''}>Skipped</option>
      </select>`;
    default:
      return '';
  }
}

function buildSortHeaderCells(cols, sorts) {
  return cols.map(({ label, col }) => {
    const sortIdx = sorts.findIndex(s => s.col === col);
    const sorted  = sortIdx !== -1;
    const dir     = sorted ? sorts[sortIdx].dir : '';
    const arrow   = dir === 'asc' ? '↑' : dir === 'desc' ? '↓' : '';
    const badge   = sorted ? `<span class="sort-badge">${sortIdx + 1}</span>` : '';
    const ind     = sorted ? `<span class="sort-indicator">${arrow}${badge}</span>` : '';
    const cls     = `sortable-th${sorted ? ' is-sorted' : ''}`;
    return `<th class="${cls}" data-sort-col="${col}">${escHtml(label)}${ind}</th>`;
  }).join('');
}

function buildFilterActiveBar(cols, filters, sorts, clearFilterId, clearSortId) {
  const hasFilter = Object.values(filters).some(v => v !== '');
  const hasSorts  = sorts.length > 0;
  const barParts  = [];
  if (hasFilter) {
    barParts.push(`Filters active <button class="btn-clear-filters" id="${clearFilterId}">Clear filters</button>`);
  }
  if (hasSorts) {
    const sortDesc = sorts.map(s => `${cols.find(c => c.col === s.col)?.label ?? s.col} ${s.dir === 'asc' ? '↑' : '↓'}`).join(' → ');
    barParts.push(`Sorted: ${escHtml(sortDesc)} <button class="btn-clear-sorts" id="${clearSortId}">Clear sorts</button>`);
  }
  return barParts.length
    ? `<div class="filter-active-bar">${barParts.join('<span class="sep"> · </span>')}</div>`
    : '';
}

function appendSortParams(params, sorts) {
  sorts.forEach((s, i) => {
    params[`sort${i + 1}_col`] = s.col;
    params[`sort${i + 1}_dir`] = s.dir;
  });
}

/** Default sorts when opening the Campaigns list (non-complete first, then priority). */
function defaultCampSorts() {
  return [{ col: 'priority', dir: 'desc' }];
}

function appendCampaignListParams(params) {
  const cf = state.campColFilters;
  if (cf.q_trade)         params.q_trade         = cf.q_trade;
  if (cf.q_status)        params.q_status        = cf.q_status;
  if (cf.q_campaign_id)   params.q_campaign_id   = cf.q_campaign_id;
  if (cf.min_priority)    params.min_priority    = cf.min_priority;
  if (cf.max_priority)    params.max_priority    = cf.max_priority;
  if (cf.progress_filter) params.progress_filter = cf.progress_filter;
  appendSortParams(params, state.campColSorts);
}

function appendCampDetailProspectParams(params) {
  const cf = state.campDetailProspectFilters;
  if (cf.q_business)     params.q_business     = cf.q_business;
  if (cf.q_contact)      params.q_contact      = cf.q_contact;
  if (cf.q_town)         params.q_town         = cf.q_town;
  if (cf.q_status)       params.q_status       = cf.q_status;
  if (cf.emailed_filter) params.emailed_filter = cf.emailed_filter;
  appendSortParams(params, state.campDetailProspectSorts);
}

function appendOutboxListParams(params) {
  const cf = state.outboxColFilters;
  if (cf.q_business)      params.q_business      = cf.q_business;
  if (cf.q_email)         params.q_email         = cf.q_email;
  if (cf.q_subject)       params.q_subject       = cf.q_subject;
  if (cf.approval_filter) params.approval_filter = cf.approval_filter;
  if (cf.sent_filter)     params.sent_filter     = cf.sent_filter;
  appendSortParams(params, state.outboxColSorts);
}

function wireColFilterSort(main, {
  cols, filters, sorts, focusKey, timerKey, onReload,
  clearFilterId, clearSortId, getDefaultSorts = null,
}) {
  main.querySelectorAll('.sortable-th').forEach(th => {
    th.addEventListener('click', () => {
      const col      = th.dataset.sortCol;
      const existing = sorts.find(s => s.col === col);
      if (existing) {
        if (existing.dir === 'asc') existing.dir = 'desc';
        else sorts.splice(sorts.findIndex(s => s.col === col), 1);
      } else if (sorts.length < 3) {
        sorts.push({ col, dir: 'asc' });
      }
      onReload({ soft: true });
    });
  });

  main.querySelectorAll('.col-filter').forEach(input => {
    input.addEventListener('focus', () => { state[focusKey] = input.dataset.col; });
    const evt = input.tagName === 'SELECT' ? 'change' : 'input';
    input.addEventListener(evt, () => {
      filters[input.dataset.col] = input.value;
      clearTimeout(state[timerKey]);
      if (input.tagName === 'SELECT') {
        onReload({ soft: true });
        return;
      }
      state[timerKey] = setTimeout(() => onReload({ soft: true }), FILTER_DEBOUNCE_MS);
    });
  });

  const focusCol = state[focusKey];
  if (focusCol) {
    requestAnimationFrame(() => {
      const el = main.querySelector(`.col-filter[data-col="${focusCol}"]`);
      if (!el || el.tagName === 'SELECT') return;
      el.focus();
      const n = el.value.length;
      if (el.setSelectionRange) el.setSelectionRange(n, n);
    });
  }

  document.getElementById(clearFilterId)?.addEventListener('click', () => {
    Object.keys(filters).forEach(k => { filters[k] = ''; });
    onReload();
  });
  document.getElementById(clearSortId)?.addEventListener('click', () => {
    sorts.length = 0;
    if (getDefaultSorts) getDefaultSorts().forEach(s => sorts.push(s));
    onReload();
  });
}

function prospectDataCell(col, row) {
  switch (col) {
    case 'business_name':
      return escHtml(row.business_name || '—');
    case 'contact_name':
      return `<span class="muted">${escHtml(row.contact_name || '—')}</span>`;
    case 'trade_category':
      return `<span class="muted">${escHtml(row.trade_category || '—')}</span>`;
    case 'town':
      return `<span class="muted">${escHtml(row.town || '—')}</span>`;
    case 'has_website':
      return `<span class="pill ${row.has_website ? 'has-website' : 'no-website'}">${row.has_website ? 'Yes' : 'No'}</span>`;
    case 'rating':
      return `<span class="muted">${row.rating != null ? row.rating : '—'}</span>`;
    case 'campaign_id': {
      const id = row.campaign_id;
      if (!id) return '<span class="muted">—</span>';
      const short = id.length > 35 ? id.slice(0, 35) + '…' : id;
      return `<span class="camp-id-cell" data-id="${escAttr(id)}" title="${escAttr(id)}">${escHtml(short)}</span>`;
    }
    case 'campaign_priority':
      return row.campaign_priority != null
        ? `<span style="font-weight:700">${escHtml(String(row.campaign_priority))}</span>`
        : '<span class="muted">—</span>';
    case 'last_email_sent':
      return `<span class="muted">${row.last_email_sent ? row.last_email_sent.slice(0, 10) : '—'}</span>`;
    case 'website_platform':
      return `<span class="muted">${escHtml(row.website_platform || '—')}</span>`;
    case 'website_agency':
      return `<span class="muted">${escHtml(row.website_agency || '—')}</span>`;
    case 'website_url': {
      const u = row.website_url;
      if (!u) return '<span class="muted">—</span>';
      return `<a href="${escAttr(u)}" target="_blank" rel="noopener" class="muted" style="color:var(--amber)">${escHtml(u.replace(/^https?:\/\//, ''))}</a>`;
    }
    case 'ch_number':
      return `<span class="muted">${escHtml(row.ch_number || '—')}</span>`;
    case 'ch_status':
      return `<span class="muted">${escHtml(row.ch_status || '—')}</span>`;
    case 'company_type':
      return `<span class="muted">${escHtml(row.company_type || '—')}</span>`;
    default:
      return '—';
  }
}

